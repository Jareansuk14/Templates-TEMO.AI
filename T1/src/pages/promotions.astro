---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE, BRAND_NAME, EXTERNAL_LINK } from "@/config/site";
import { getPromotionSeoHeading, getPromotionSeoDescription } from "@/lib/seo-content";
import { PROMOS } from "@/lib/images";

const promotionSeo = getPromotionSeoHeading();
const pageDescription = getPromotionSeoDescription();

const promoKeywords: string[] = [];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `โปรโมชั่น ${SITE.name}`,
  description: pageDescription,
  url: `${SITE.url}/promotions/`,
  numberOfItems: PROMOS.length,
};
---

<BaseLayout
  title={`โปรโมชั่น ${SITE.name} | ${promotionSeo}`}
  description={pageDescription}
  keywords={[SITE.name, ...promoKeywords].join(", ")}
  jsonLd={jsonLd}
>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">หน้าแรก</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <span aria-current="page">โปรโมชั่น</span>
      </nav>
      <h1 id="promotion-seo"><span class="section-brand">{BRAND_NAME}</span>โปรคาสิโนออนไลน์ จัดเต็ม โบนัสแรง คืนยอดรายวัน สมาชิกใหม่คุ้ม เงื่อนไขชัด ชวนเพื่อนรับรางวัล</h1>
      <p id="sub-promotion-seo">โปรโมชันจาก TEMO888 ออกแบบให้ใช้งานจริง เลือกรับได้ตามสไตล์ ตั้งแต่โบนัสต้อนรับ เครดิตทดลอง รายวัน/รายสัปดาห์ ไปจนถึงคืนยอดเสียตามระดับสมาชิก ระบบเว็บตรงคำนวณและลงโบนัสให้อัตโนมัติ ตรวจสอบได้ในประวัติธุรกรรมทันที มีข้อเสนอเฉพาะเกมสำหรับ คาสิโนออนไลน์ สล็อต บาคาร่า และ แทงบอล เพื่อความคุ้มค่าสูงสุด โปรชวนเพื่อนรับค่าคอมต่อเนื่อง พร้อมโปรวีไอพี ของรางวัลพรีเมียม และผู้จัดการบัญชีเฉพาะทาง ทุกขั้นตอนปลอดภัย รวดเร็ว โปร่งใส</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="promo-grid-5">
        {PROMOS.map(({ src, alt, width, height }, i) => (
          <a
            href={EXTERNAL_LINK}
            class="promo-full-card"
            aria-label={alt}
          >
            <img
              src={src}
              alt={alt}
              width={width}
              height={height}
              loading={i < 2 ? "eager" : "lazy"}
              decoding="async"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
