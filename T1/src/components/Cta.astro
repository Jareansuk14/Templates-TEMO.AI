---
import { BRAND_NAME } from "@/config/site";
import { ACTION_BUTTONS } from "@/lib/images";

interface Props {
  externalLink: string;
}
const { externalLink } = Astro.props;

const register = ACTION_BUTTONS.register;
const contact = ACTION_BUTTONS.contact;
---

<!-- CTA BOTTOM -->
<section class="cta-section" aria-labelledby="cta-seo">
  <div class="container">
    <h2 id="cta-seo"><span class="section-brand">{BRAND_NAME}</span>สมัครเว็บตรงวันนี้ รับเครดิตฟรี เริ่มเล่น คาสิโนออนไลน์ ทันที ออโต้ไว คุ้มและปลอดภัย</h2>
    <p class="cta-desc" id="sub-cta-seo">ลงทะเบียน TEMO888 ใช้เวลาไม่กี่นาที รับโบนัสต้อนรับและเครดิตฟรีทดลองทันที เสริมความมั่นใจด้วยยืนยันตัวตนสองขั้นและระบบความปลอดภัยครบ ศูนย์ช่วยเหลือภาษาไทยตอบไว 24 ชม. ฝากถอนออโต้ผ่านธนาคารและวอลเล็ตยอดนิยม บัญชีเดียวเล่นได้ทุกหมวด พนันออนไลน์ ตั้งแต่ คาสิโนออนไลน์ สล็อต บาคาร่า ไปจนถึง แทงบอล มีโหมดเดโมและคู่มือใช้งานอ่านง่าย อินเทอร์เฟซเหมาะกับมือถือ ปรับความเป็นส่วนตัวได้เอง โปรฯ เงื่อนไขโปร่งใส ตรวจสอบและกดรับผ่านโปรไฟล์ได้เลย</p>
    <div class="hero-action-pair">
      <a href={externalLink} class="hero-action-link" aria-label={register.alt}>
        <img src={register.src} alt={register.alt} width={register.width} height={register.height} loading="lazy" decoding="async" />
      </a>
      <a href="/contact/" class="hero-action-link" aria-label={contact.alt}>
        <img src={contact.src} alt={contact.alt} width={contact.width} height={contact.height} loading="lazy" decoding="async" />
      </a>
    </div>
  </div>
</section>
