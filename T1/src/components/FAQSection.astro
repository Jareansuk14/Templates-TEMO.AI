---
import { BRAND_NAME } from "@/config/site";

const faqs = [
  { q: "ระบบฝากถอน ใช้เวลากี่นาที หากถอนเงินไม่ได้ควรทำอย่างไร ?", a: "ระบบฝาก-ถอนออโต้ของเราประมวลผลได้อย่างรวดเร็วทันใจ ยอดเงินจะเข้าบัญชีภายในเวลาไม่กี่วินาที (ไม่เกิน 1 นาที) โดยไม่ต้องส่งสลิป หากเกิดกรณีที่ท่านถอนเงินไม่ได้ หรือเงินเข้าล่าช้า ส่วนใหญ่เกิดจากระบบปรับปรุงสัญญาณของธนาคารปลายทาง หรือกรอกข้อมูลบัญชีไม่ตรงกับตอนสมัคร วิธีแก้ไขเบื้องต้น: ให้ตรวจสอบความถูกต้องของเลขบัญชี หรือแคปหน้าจอทำรายการแล้วทักหาแอดมินผ่านช่องทาง LINE เพื่อรับการตรวจสอบและแก้ไขให้ทันทีตลอด 24 ชั่วโมง" },
  { q: "ศูนย์รวมความสนุกครบวงจร มีเกมอะไรที่น่าสนใจและไม่ควรพลาดบ้าง?", a: "สมาชิกสามารถเลือกสรรความบันเทิงได้หลากหลายรูปแบบ ทั้งคาสิโนสด สล็อตแมชชีน และเกมกราฟิก 3D จากค่ายดังระดับสากล ตัวเว็บไซต์รันบนทุกระบบเว็บ คาสิโนที่ควรมี ที่ใช้เทคโนโลยีกระเป๋าเงินเดียว ทำให้คุณสามารถสลับเล่นเกมยอดฮิตได้ทันทีโดยไม่ต้องโยกย้ายเงินให้ซับซ้อน" },
  { q: "แพลตฟอร์มนี้เปิดให้บริการอย่างถูกต้องตามกฎหมายสากลหรือเปล่า?", a: "เปิดให้บริการอย่างถูกต้องตามกฎหมายสากล ภายใต้การกำกับดูแลและได้รับใบอนุญาตประกอบธุรกิจ iGaming จากหน่วยงานต่างประเทศอย่างเป็นทางการ ตัวระบบผ่านการตรวจสอบมาตรฐานโครงสร้างและอัลกอริทึมที่เป็นธรรมจากองค์กรอิสระระดับสากล สมาชิกทุกท่านจึงมั่นใจได้ว่าการเข้าใช้งานและการคุ้มครองข้อมูลส่วนบุคคลจะเป็นไปตามหลักมาตรฐานความปลอดภัยทางกฎหมายสูงสุด" },
  { q: "สถานะทางการเงินของเว็บพร้อมจ่ายยอดกำไรหลักล้านทันทีจริงหรือไม่?", a: "พร้อมจ่ายยอดเต็มจำนวนจริง 100% ด้วยทุนหมุนเวียนที่มั่นคงสูงและระบบสำรองทางการเงินที่ได้มาตรฐานระดับสากล แพลตฟอร์มของเราใช้ระบบฝาก-ถอนออโต้ที่มีประสิทธิภาพในการประมวลผลธุรกรรมขนาดใหญ่ ทำให้สามารถอนุมัติและโอนยอดกำไรหลักแสนหรือหลักล้านเข้าสู่บัญชีของสมาชิกได้ทันทีอย่างแม่นยำ โดยไม่มีนโยบายดึงเช็งหรือหักเปอร์เซ็นต์ค่านายหน้าใดๆ ทั้งสิ้น" },
  { q: "เว็บนี้เปิดให้บริการมานานแค่ไหน มีฐานผู้ใช้งานจริงเยอะไหม?", a: "เราเปิดให้บริการและพัฒนาซอฟต์แวร์อย่างต่อเนื่องจนก้าวสู่ปี 2026 พร้อมฐานสมาชิกผู้ใช้งานจริงที่เหนียวแน่นและเติบโตขึ้นในทุกๆ ปี ความสำเร็จและจำนวนผู้ใช้งานที่หนาแน่นนี้ เป็นสิ่งพิสูจน์ถึงระบบหลังบ้านที่มีเสถียรภาพสูง มาตรฐาน API แท้ที่โปร่งใส และการบริการที่ซื่อสัตย์ตรงไปตรงมา จนเกิดการบอกต่อและได้รับความไว้วางใจจากนักลงทุนทั่วทั้งภูมิภาค" },
  { q: "ติดต่อแอดมิน ได้ช่องทางไหนบ้าง ? โปรโมชั่น มีเงื่อนไขอะไรบ้าง ?", a: "คุณสามารถติดต่อทีมงานแอดมินระดับมืออาชีพของเราได้ง่าย ๆ ผ่านทาง LINE Official (คลิกที่ปุ่มติดต่อเราบนหน้าเว็บไซต์) ซึ่งพร้อมให้บริการดูแลและซัพพอร์ตตลอด 24 ชั่วโมง ในส่วนของโปรโมชั่น เว็บของเรามีข้อเสนอสุดคุ้มอัปเดตใหม่เสมอ เช่น โบนัสต้อนรับสมาชิกใหม่, เครดิตฟรีวันเกิด หรือยอดคืนยอดเสีย โดยเงื่อนไขจะขึ้นอยู่กับแต่ละกิจกรรม (เช่น การทำเทิร์นโอเวอร์ต่ำ หรือการถอนได้ไม่จำกัด) ซึ่งสามารถตรวจสอบเงื่อนไขอย่างละเอียดได้ที่เมนูโปรโมชั่นหรือสอบถามแอดมินได้ทันที" }
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: a },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

<section class="faq-footer" aria-labelledby="faq-global-heading">
  <div class="container">
    <header class="section-header">
      <span class="section-brand">{BRAND_NAME}</span>
      <h2 id="faq-global-heading">คำถามที่พบบ่อย</h2>
      <div class="gold-line"></div>
    </header>
    <div class="faq-grid">
      {faqs.map(({ q, a }, i) => (
        <details class="faq-item">
          <summary id={`faq-q-${i + 1}`}>{q}</summary>
          <p class="faq-answer" id={`faq-a-${i + 1}`}>{a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
