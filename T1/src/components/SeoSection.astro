---
import { BRAND_NAME } from "@/config/site";
import { SEO_ARTICLE_IMAGES } from "@/lib/images";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const whySections = [
  { id: "seo-1", heading: "สล็อต เว็บตรง แตกหนัก RTP ชัด โบนัสจัดเต็ม ฝากถอนออโต้ รองรับวอลเล็ต จ่ายไว", desc: "ที่ TEMO888 คุณจะพบสล็อตจากค่ายชั้นนำพร้อมข้อมูลสำคัญครบ เช่น RTP ช่วงความผันผวน จำนวนเพย์ไลน์ และฟีเจอร์พิเศษ ตรวจสอบได้ก่อนหมุนจริง ลองเล่นโหมดเดโมเพื่อจับจังหวะและวางแผนงบอย่างมีวินัย จากนั้นค่อยปรับเบทตามกลยุทธ์ ฝากถอนออโต้ผ่านธนาคารและวอลเล็ต ทำรายการเร็ว ปลอดภัย และไม่เด้งออกจากหน้าเกม แยกหมวดชัดเจนทั้งคลาสสิก เมกะเวย์ ซื้อฟรีสปิน และแจ็กพอตสะสม หนึ่งบัญชีเชื่อม คาสิโนออนไลน์ สล็อต บาคาร่า แทงบอล บนเว็บตรง โปรรายวัน ภารกิจ และสะสมแต้มช่วยต่อยอดกำไร" },
  { id: "seo-2", heading: "บาคาร่าสด เว็บตรง คมชัดไม่หน่วง เล่นได้ 24 ชม. มือถือสะดวก ระบบออโต้ ปลอดภัยสูง", desc: "TEMO888 บริการบาคาร่าสดผ่านเว็บตรง ภาพคมชัด หน่วงต่ำ มีห้องให้เลือกทั้งสปีด คลาสสิก และโมเดิร์น พร้อมสถิติย้อนหลังและเค้าไพ่แบบเรียลไทม์ช่วยวิเคราะห์เดิมพัน มือใหม่เริ่มจากโหมดสาธิตและบทเรียนพื้นฐานได้ก่อน ฝากถอนออโต้ปลอดภัย รองรับธนาคารและวอลเล็ต 24 ชม. อินเทอร์เฟซมือถือแนวตั้ง-แนวนอน เปลี่ยนโต๊ะได้รวดเร็ว บัญชีเดียวสลับไปยัง คาสิโนออนไลน์ สล็อต หรือ แทงบอล ได้ทันที โปรโมชันระบุเงื่อนไขชัด ตรวจสอบยอดรับ ยอดคืน และประวัติการเล่นได้ครบ" },
  { id: "seo-3", heading: "แทงบอล เว็บตรง ครบลีก ราคาน้ำโดนใจ มีสถิติ-ถ่ายทอดสด มือถือก็ลื่น บริการไทยตลอดคืน", desc: "TEMO888 เปิดรับพนันบอลครบทุกลีก ทั้งยุโรป เอเชีย และรายการพิเศษ ราคาน้ำอัปเดตทันใจ เลือกเล่นได้ทั้งเต็ง-สเต็ป สูงต่ำ และบอลสด หน้าสถิติสด แผนผังเกม และฟีดถ่ายทอดช่วยให้ตัดสินใจแม่นยำ ระบบเว็บตรงเสถียร ฝากถอนออโต้รองรับธนาคาร/วอลเล็ตตลอดวัน ใช้งานบนมือถือและแท็บเล็ตลื่นไหล มีโหมดมืดถนอมตา ศูนย์ช่วยเหลือภาษาไทย 24 ชม. บัญชีเดียวเข้าถึง คาสิโนออนไลน์ สล็อต บาคาร่า และกีฬาอื่นๆ โปรเงื่อนไขชัด ตรวจสอบยอดคืนและประวัติบิลได้ทันที" },
];
---

<!-- Alternating image + article rows -->
<div class="seo-rows">
  {whySections.map(({ id, heading, desc }, index) => {
    const image = SEO_ARTICLE_IMAGES[id];
    const isEven = index % 2 === 1;
    return (
      <div class={`seo-row${isEven ? " seo-row--reverse" : ""}`}>
        <a href={externalLink} class="seo-img-link" aria-label={image.alt} id={id}>
          <img src={image.src} alt={image.alt} width={image.width} height={image.height} loading="lazy" decoding="async" />
        </a>
        <article class="seo-art-box" aria-labelledby={`${id}-title`}>
          <h2 id={`${id}-title`}><span class="section-brand">{BRAND_NAME}</span>{heading}</h2>
          <p id={`sub-${id}`}>{desc}</p>
        </article>
      </div>
    );
  })}
</div>
