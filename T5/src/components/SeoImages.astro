---
import { SEO_ARTICLE_IMAGES } from "@/lib/images";

interface Props {
  externalLink: string;
}
const { externalLink } = Astro.props;

const images = [
  SEO_ARTICLE_IMAGES["seo-1"],
  SEO_ARTICLE_IMAGES["seo-2"],
  SEO_ARTICLE_IMAGES["seo-3"],
];
---

<section class="seo-images-section" aria-label="SEO article images">
  <div class="container">
    <div class="seo-images-grid">
      {images.map((image) => (
        <a
          href={externalLink}
          class="seo-img-wrap"
          aria-label={image.alt}
        >
          <img
            src={image.src}
            alt={image.alt}
            width={image.width}
            height={image.height}
            loading="lazy"
            decoding="async"
          />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
  .seo-images-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1rem;
  }

  .seo-img-wrap {
    display: block;
    cursor: pointer;
  }

  .seo-img-wrap img {
    width: 100%;
    height: auto;
    display: block;
  }

  @media (max-width: 768px) {
    .seo-images-grid {
      grid-template-columns: 1fr;
      gap: 0.75rem;
    }
  }
</style>
