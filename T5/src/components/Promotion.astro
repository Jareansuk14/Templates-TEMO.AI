---
import { getPromoPreview, PROMO_PREVIEW_SIZE } from "@/lib/images";

interface Props {
  externalLink: string;
}
const { externalLink } = Astro.props;

const promos = getPromoPreview(3);
const { width: previewWidth, height: previewHeight } = PROMO_PREVIEW_SIZE;
---

<!-- PROMOTIONS PREVIEW -->
<section class="section section-alt section-intro" aria-labelledby="promo-heading">
  <div class="container">
    <header class="section-header">
      <h2 id="promo-heading">โปรโมชั่นพิเศษ</h2>
      <div class="gold-line"></div>
    </header>
    <p class="section-desc">รวมโปรโมชั่นสุดฮิตไว้ครบในเว็บเดียว ทั้งโบนัสสมาชิกใหม่ คืนยอดเสีย กิจกรรมลุ้นรางวัล และเครดิตฟรีอีกมากมาย รองรับผู้เล่นทุกสาย ไม่ว่าจะเป็นสล็อต บาคาร่า คาสิโนสด หรือเกมเดิมพันออนไลน์อื่น ๆ พร้อมอัปเดตโปรโมชั่นใหม่ทุกวัน เพื่อให้สมาชิกได้รับความคุ้มค่าสูงสุดในทุกการเดิมพัน</p>
    <div style="text-align:center;margin-top:1rem">
      <a href="/promotions/" class="btn btn-outline-gold btn-lg">ดูโปรโมชั่นทั้งหมด →</a>
    </div>
  </div>
</section>

<section class="promo-images-section" aria-label="โปรโมชั่นพิเศษ รูปภาพ">
  <div class="container">
    <div class="promo-preview-grid">
      {promos.map(({ alt, src }) => (
        <a href={externalLink} class="promo-img-card" aria-label={alt}>
          <img
            src={src}
            alt={alt}
            width={previewWidth}
            height={previewHeight}
            loading="lazy"
            decoding="async"
          />
        </a>
      ))}
    </div>
  </div>
</section>
