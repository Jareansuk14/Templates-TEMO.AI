---
import { BRAND_NAME } from "@/config/site";
import { ACTION_BUTTONS } from "@/lib/images";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const register = ACTION_BUTTONS.register;
const contact = ACTION_BUTTONS.contact;
---

<!-- CTA BOTTOM -->
<section class="cta-section" aria-labelledby="cta-seo">
  <div class="container">
    <h2 id="cta-seo"><span class="section-brand">{BRAND_NAME}</span>สมัครสมาชิกเว็บตรงวันนี้ รับเครดิตฟรี เริ่มเดิมพัน คาสิโนออนไลน์ ทันที ปลอดภัย ฝากถอนออโต้ คุ้มค่า</h2>
    <p class="cta-desc" id="sub-cta-seo">สมัครสมาชิกกับ 375KUB ใช้เวลาไม่กี่นาที ก็พร้อมรับสิทธิพิเศษทันที เริ่มจากโบนัสต้อนรับ เครดิตฟรีทดลอง ระบบยืนยันตัวตนสองชั้น และศูนย์ช่วยเหลือภาษาไทยที่ตอบไว ลงทะเบียนเสร็จสามารถฝากถอนออโต้ผ่านธนาคารและวอลเล็ตยอดนิยม ทำรายการได้ตลอด 24 ชั่วโมง บัญชีเดียวเข้าถึง พนันออนไลน์ ครบวงจร ทั้ง คาสิโนออนไลน์ สล็อต บาคาร่า แทงบอล และกีฬาเสมือน พร้อมโหมดทดลองเล่นและคู่มือการใช้งานที่อธิบายขั้นตอนอย่างชัดเจน เว็บตรงออกแบบอินเทอร์เฟซให้อ่านง่าย รองรับมือถือเต็มรูปแบบ พร้อมตั้งค่าความเป็นส่วนตัวได้ด้วยตนเอง โปรโมชันเงื่อนไขโปร่งใส ตรวจสอบได้ในหน้าโปรไฟล์ กดรับง่าย เริ่มตอนนี้เพื่อโอกาสใหม่ที่ทั้งคุ้มค่าและปลอดภัย</p>
    <div class="hero-action-pair">
      <a href={externalLink} class="hero-action-link" aria-label={register.alt}><img src={register.src} alt={register.alt} width={register.width} height={register.height} loading="lazy" decoding="async" /></a>
      <a href="/contact/" class="hero-action-link" aria-label={contact.alt}><img src={contact.src} alt={contact.alt} width={contact.width} height={contact.height} loading="lazy" decoding="async" /></a>
    </div>
  </div>
</section>
