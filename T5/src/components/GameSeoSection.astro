---
import { BRAND_NAME } from "@/config/site";
import { GAME_CARDS } from "@/lib/images";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const group1 = GAME_CARDS.slice(0, 3);
const group2 = GAME_CARDS.slice(3, 6);

const seoSections = [
  { id: "seo-1", heading: "สล็อตออนไลน์ แตกง่าย โบนัสเพียบ จ่ายจริง เว็บตรง ฝากถอนออโต้ RTP รองรับวอลเล็ต", desc: "375KUB รวบรวมเกมสล็อตจากผู้ให้บริการชั้นนำ โดยเน้นความโปร่งใสของค่า RTP ความผันผวน และโครงสร้างเพย์ไลน์ให้ตรวจสอบก่อนเดิมพัน คุณสามารถทดลองเล่นเพื่อทำความเข้าใจจังหวะเกม ฟีเจอร์พิเศษ และการจ่ายในแต่ละรอบ จากนั้นค่อยวางแผนงบแบบเป็นขั้นตอน ระบบฝากถอนออโต้รองรับธนาคารหลักและวอลเล็ต ใช้งานได้เร็ว ปลอดภัย และไม่เสียเวลาเปลี่ยนหน้าจอ หมวดหมู่ค้นหาช่วยแยกแนวทางชัดเจน เช่น คลาสสิก เมกะเวย์ ซื้อฟรีสปิน และแจ็กพอตสะสม มีรีวิวรายละเอียดโบนัส รอบฟรีสปิน และสถิติการเข้ารางวัลอัปเดตสม่ำเสมอ เดิมพันผ่านเว็บตรงที่รวม คาสิโนออนไลน์ สล็อต บาคาร่า แทงบอล ในบัญชีเดียว โปรโมชันรายวัน รายสัปดาห์ และภารกิจสะสมแต้ม เพิ่มโอกาสรับรางวัลอย่างยุติธรรม เหมาะกับทั้งผู้เริ่มต้นและสายทำกำไรระยะยาว" },
  { id: "seo-2", heading: "บาคาร่าออนไลน์สด ภาพคมชัด เว็บตรง ปลอดภัย ระบบออโต้ 24 ชั่วโมง ไม่มีสะดุด รองรับมือถือ", desc: "375KUB ให้บริการบาคาร่าออนไลน์สดผ่านเว็บตรงที่ได้มาตรฐาน ภาพคมชัดดีเลย์ต่ำ ห้องหลากหลายสไตล์ ทั้งสปีด โมเดิร์น และคลาสสิก พร้อมสถิติย้อนหลังและเค้าไพ่แบบเรียลไทม์เพื่อช่วยวิเคราะห์จังหวะเดิมพัน โหมดสาธิตและบทเรียนเบื้องต้นช่วยฝึกอ่านโต๊ะและบริหารงบ ก่อนย้ายไปเล่นเงินจริงอย่างมั่นใจ ระบบฝากถอนออโต้ปลอดภัย รองรับธนาคารชั้นนำและวอลเล็ต ทำรายการได้ตลอด 24 ชั่วโมง อินเทอร์เฟซรองรับมือถือแนวตั้งแนวนอน เปลี่ยนโต๊ะรวดเร็ว ไม่พลาดรอบสำคัญ นอกจากบาคาร่า คุณยังสลับไปเล่น คาสิโนออนไลน์ สล็อต แทงบอล และเกมคาสิโนสดอื่นๆ ได้ทันทีในบัญชีเดียว เงื่อนไขโปรโมชันโปร่งใส แจ้งชัดเจน ตรวจสอบยอดรับ ยอดคืน และบันทึกการเดิมพันได้ครบถ้วน ช่วยให้การวางแผนเป็นระบบ" },
];
---

<div class="gs-row">
  <div class="gs-cell"><div class="container"><div class="gs-games-group">{group1.map(({ alt, src, width, height }) => (<a href={externalLink} class="game-img-card" aria-label={alt}><img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" /></a>))}</div></div></div>
  <section id="seo-1" class="gs-cell why-feature-section" aria-labelledby="seo-1-title"><div class="container"><div class="why-feat-content"><h2 id="seo-1-title"><span class="section-brand">{BRAND_NAME}</span>{seoSections[0].heading}</h2><p id="sub-seo-1">{seoSections[0].desc}</p></div></div></section>
</div>
<div class="gs-row section-alt">
  <section id="seo-2" class="gs-cell why-feature-section section-alt" aria-labelledby="seo-2-title"><div class="container"><div class="why-feat-content"><h2 id="seo-2-title"><span class="section-brand">{BRAND_NAME}</span>{seoSections[1].heading}</h2><p id="sub-seo-2">{seoSections[1].desc}</p></div></div></section>
  <div class="gs-cell"><div class="container"><div class="gs-games-group">{group2.map(({ alt, src, width, height }) => (<a href={externalLink} class="game-img-card" aria-label={alt}><img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" /></a>))}</div></div></div>
</div>
<style>
  .gs-row { display: grid; grid-template-columns: 1fr 1fr; align-items: start; }
  .gs-cell { background: inherit; }
  .gs-games-group { display: grid; grid-template-columns: repeat(3, 1fr); gap: 0.75rem; padding: 1.5rem 0; }
  .gs-games-group .game-img-card { border: none; border-radius: 0; overflow: visible; transition: transform 0.25s ease; }
  .gs-games-group .game-img-card:hover { transform: translateY(-8px); }
  @media (hover: none) { .gs-games-group .game-img-card:hover { transform: none; } }
  .gs-games-group .game-img-card img { width: 100%; height: auto; aspect-ratio: auto; object-fit: unset; }
  .why-feat-content { text-align: left; }
  @media (max-width: 1024px) { .gs-row { grid-template-columns: 1fr; } .gs-row.section-alt > :first-child { order: 2; } .gs-row.section-alt > :last-child { order: 1; } }
  @media (max-width: 768px) { .gs-games-group { grid-template-columns: repeat(3, 1fr); gap: 0.375rem; padding: 0.75rem 0; max-width: 80%; margin-inline: auto; } }
  @media (max-width: 480px) { .gs-games-group { gap: 0.25rem; padding: 0.5rem 0; max-width: 75%; } }
</style>
