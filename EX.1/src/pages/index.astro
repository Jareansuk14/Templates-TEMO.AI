---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Banner from "@/components/Banner.astro";
import { SITE, EXTERNAL_LINK } from "@/config/site";
import { getMainSeoHeading, getMainSeoDescription } from "@/lib/seo-content";
import { BANNER, getLogoSrc } from "@/lib/images";
import CtaBar from "@/components/sections/Cta.astro";
import HeroCompact from "@/components/sections/Hero.astro";
import PromotionMascotSide2 from "@/components/sections/Promotion.astro";
import SeoBoxSide3 from "@/components/sections/Seo.astro";
import "@/styles/sections.generated.css";
const mainSeo = getMainSeoHeading();
const pageDescription = getMainSeoDescription();

const indexKeywords: string[] = [];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.name,
  url: SITE.url,
  logo: `${SITE.url}${getLogoSrc()}`,
  description: pageDescription,
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer service",
    availableLanguage: "Thai",
  },
};
---

<BaseLayout
  title={`${SITE.name} | ${mainSeo}`}
  description={pageDescription}
  keywords={[SITE.name, ...indexKeywords].join(", ")}
  ogType="website"
  jsonLd={jsonLd}
  preloadImage={BANNER.src}
>
    <Banner />
  <SeoBoxSide3 externalLink={EXTERNAL_LINK} />
  <CtaBar externalLink={EXTERNAL_LINK} />
  <HeroCompact externalLink={EXTERNAL_LINK} />
  <PromotionMascotSide2 externalLink={EXTERNAL_LINK} />
</BaseLayout>
