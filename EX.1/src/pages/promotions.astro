---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE } from "@/config/site";
import { getPromotionSeoHeading, getPromotionSeoDescription } from "@/lib/seo-content";
import { PROMOS } from "@/lib/images";
import PromotionsBody from "@/components/page/PromotionsBody.astro";

const promotionSeo = getPromotionSeoHeading();
const pageDescription = getPromotionSeoDescription();

const promoKeywords: string[] = [];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `โปรโมชั่น ${SITE.name}`,
  description: pageDescription,
  url: `${SITE.url}/promotions/`,
  numberOfItems: PROMOS.length,
};
---

<BaseLayout
  title={`โปรโมชั่น ${SITE.name} | ${promotionSeo}`}
  description={pageDescription}
  keywords={[SITE.name, ...promoKeywords].join(", ")}
  jsonLd={jsonLd}
>
  <PromotionsBody />
</BaseLayout>
