---
import { BRAND_NAME } from "@/config/site";
import { ACTION_BUTTONS } from "@/lib/images";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const login = ACTION_BUTTONS.login;
const register = ACTION_BUTTONS.register;
---

<section class="hero-below" aria-labelledby="main-seo">
  <div class="container">
    <h1 id="main-seo"><span class="section-brand">{BRAND_NAME}</span>เว็บตรงพนันออนไลน์ คาสิโน สล็อต บาคาร่า บอลครบ</h1>
    <p class="hero-desc" id="sub-main-seo">เลือก TEMO888 เว็บตรงสำหรับสายพนันออนไลน์ที่ต้องการความครบในที่เดียว มีทั้ง คาสิโนออนไลน์ สล็อต บาคาร่า แทงบอล และเกมไลฟ์สดค่ายดัง สมัครง่ายผ่านมือถือ ฝากถอนออโต้ไว ระบบเข้ารหัสปลอดภัย พร้อมโปรสมาชิกใหม่และทีมงานไทยดูแลตลอดวัน</p>
    <div class="hero-action-pair">
      <a href={externalLink} class="hero-action-link" aria-label={login.alt}>
        <img src={login.src} alt={login.alt} width={login.width} height={login.height} loading="eager" decoding="async" />
      </a>
      <a href={externalLink} class="hero-action-link" aria-label={register.alt}>
        <img src={register.src} alt={register.alt} width={register.width} height={register.height} loading="eager" decoding="async" />
      </a>
    </div>
  </div>
</section>
