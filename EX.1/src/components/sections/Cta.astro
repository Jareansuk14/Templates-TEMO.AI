---
import { ACTION_BUTTONS } from "@/lib/images";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const register = ACTION_BUTTONS.register;
---

<section class="hero-below cta-section" aria-labelledby="cta-seo">
  <div class="container">
    <h2 id="cta-seo">สมัครเว็บตรงวันนี้ รับโบนัสเริ่มเล่นคาสิโน</h2>
    <p class="hero-desc cta-desc" id="sub-cta-seo">เริ่มต้นกับ TEMO888 ได้ง่ายในไม่กี่ขั้นตอน สมัครเว็บตรงผ่านมือถือ ยืนยันไว รับโบนัสต้อนรับตามเงื่อนไข แล้วเข้าเล่น คาสิโนออนไลน์ สล็อต บาคาร่า แทงบอล ได้ทันที ระบบฝากถอนออโต้รองรับหลายช่องทาง มีทีมไทยคอยแนะนำการใช้งานและโปรที่เหมาะกับคุณ</p>
    <div class="hero-action-pair hero-action-single">
      <a href={externalLink} class="hero-action-link" aria-label={register.alt}>
        <img src={register.src} alt={register.alt} width={register.width} height={register.height} loading="lazy" decoding="async" />
      </a>
    </div>
  </div>
</section>
