---
import { BRAND_NAME } from "@/config/site";
import { SEO_ARTICLE_IMAGES } from "@/lib/images";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const whySections = [
  { id: "seo-1", heading: "สล็อตเว็บตรงแตกง่าย โบนัสแน่น เล่นได้ทุกค่าย", desc: "TIGER888 รวมสล็อตเว็บตรงจากค่ายยอดนิยม ภาพสวย โหลดไว มีเกมใหม่ อัตราจ่ายน่าสนใจ และฟีเจอร์โบนัสให้เลือกหลากหลาย มือใหม่เริ่มได้ไม่ซับซ้อน บัญชีเดียวต่อยอดไปเล่น คาสิโนออนไลน์ บาคาร่า แทงบอล ได้ทันที พร้อมระบบฝากถอนออโต้ที่ตรวจสอบได้" },
  { id: "seo-2", heading: "บาคาร่าออนไลน์โต๊ะสด ลื่นชัด เดิมพันมั่นใจ", desc: "สัมผัสบาคาร่าออนไลน์กับ TIGER888 ผ่านดีลเลอร์สดแบบเรียลไทม์ โต๊ะให้เลือกเยอะ ภาพคม เล่นลื่นบนมือถือ มีสถิติย้อนหลังช่วยตัดสินใจก่อนลงเดิมพัน เหมาะทั้งผู้เล่นใหม่และสายจริงจัง ฝากถอนรวดเร็ว และยังเข้าถึง สล็อต คาสิโนออนไลน์ แทงบอล ได้ครบ" },
  { id: "seo-3", heading: "แทงบอลเว็บตรง ราคาสวย ครบลีกดังทั่วโลก", desc: "TIGER888 เปิดประสบการณ์แทงบอลเว็บตรงที่รวมลีกใหญ่และลีกย่อยไว้ครบ ทั้งบอลเต็ง บอลสเต็ป สูงต่ำ แฮนดิแคป และบอลสด ราคาน้ำอัปเดตต่อเนื่อง วางบิลง่ายผ่านมือถือ ใช้กระเป๋าเดียวกับ คาสิโนออนไลน์ สล็อต บาคาร่า สะดวก ปลอดภัย และรวดเร็ว" },
];
---

<div class="seo-rows">
  {whySections.map(({ id, heading, desc }, index) => {
    const image = SEO_ARTICLE_IMAGES[id];
    const isEven = index % 2 === 1;
    return (
      <div class={`seo-row${isEven ? " seo-row--reverse" : ""}`}>
        <a href={externalLink} class="seo-img-link" aria-label={image.alt} id={id}>
          <img src={image.src} alt={image.alt} width={image.width} height={image.height} loading="lazy" decoding="async" />
        </a>
        <article class="seo-art-box" aria-labelledby={`${id}-title`}>
          <h2 id={`${id}-title`}><span class="section-brand">{BRAND_NAME}</span>{heading}</h2>
          <p id={`sub-${id}`}>{desc}</p>
        </article>
      </div>
    );
  })}
</div>
