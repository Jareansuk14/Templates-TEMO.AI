---
import { SEO_ARTICLE_IMAGES } from "@/lib/images";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const whySections = [
  { id: "seo-1", heading: "เปิดประสบการณ์สล็อตเว็บตรง TEMO888 เกมไว โบนัสคุ้ม", desc: "การเลือกสล็อตที่ TEMO888 ทำได้ง่ายเพราะจัดหมวดตามค่ายเกมและสไตล์การเล่นไว้ชัดเจน ส่วนตัวชอบดูค่า RTP ตารางจ่าย และความถี่ฟรีสปินก่อนเริ่มหมุน เพราะช่วยวางทุนได้ดีกว่าไล่กดสุ่ม ระบบแสดงยอดเครดิตไว ทำให้สลับเกมสล็อตแตกง่ายที่กำลังนิยมได้ต่อเนื่อง" },
  { id: "seo-2", heading: "เล่นสล็อตแตกง่ายกับ TEMO888 ฝากถอนออโต้ ไม่สะดุด", desc: "TEMO888 เด่นตรงฝากถอนออโต้ที่ทำรายการได้ไว โดยเฉพาะช่วงที่เจอจังหวะโบนัสหรืออยากเปลี่ยนค่ายเกมทันที จากประสบการณ์ใช้งานจริง เครดิตอัปเดตในระบบชัด ตรวจย้อนหลังได้ ทำให้เล่นสล็อตเว็บตรงได้มั่นใจกว่าเว็บที่ต้องรอแอดมินและเสี่ยงเสียจังหวะฟรีสปิน" },
  { id: "seo-3", heading: "คัดค่ายเกม RTP สูงใน TEMO888 หมุนสนุก ลุ้นฟรีสปิน", desc: "ถ้าต้องการเล่นสล็อตให้มีแผน TEMO888 ช่วยให้ดูข้อมูลเกมได้เป็นระบบ ผมมักเริ่มจากเกมที่มี RTP ชัด ความผันผวนเหมาะกับทุน และฟีเจอร์ฟรีสปินที่เข้าใจง่าย วิธีนี้ไม่ได้การันตีแตกทุกตา แต่ช่วยลดการเล่นแบบเดาสุ่มและทำให้เลือกสล็อตแตกง่ายตามสไตล์ตัวเองได้แม่นขึ้น" },
];
---

<div class="seo-rows">
  {whySections.map(({ id, heading, desc }, index) => {
    const image = SEO_ARTICLE_IMAGES[id];
    const isEven = index % 2 === 1;
    return (
      <div class={`seo-row${isEven ? " seo-row--reverse" : ""}`}>
        <a href={externalLink} class="seo-img-link" aria-label={image.alt} id={id}>
          <img src={image.src} alt={image.alt} width={image.width} height={image.height} loading="lazy" decoding="async" />
        </a>
        <article class="seo-art-box" aria-labelledby={`${id}-title`}>
          <h2 id={`${id}-title`}>{heading}</h2>
          <p id={`sub-${id}`}>{desc}</p>
        </article>
      </div>
    );
  })}
</div>
