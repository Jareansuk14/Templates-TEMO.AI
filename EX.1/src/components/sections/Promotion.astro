---
import { getPromoPreview, PROMO_PREVIEW_SIZE } from "@/lib/images";

interface Props {
  externalLink: string;
}
const { externalLink } = Astro.props;

const promos = getPromoPreview(3);
const { width: previewWidth, height: previewHeight } = PROMO_PREVIEW_SIZE;
---

<!-- PROMOTIONS PREVIEW -->
<section class="section section-alt section-intro" aria-labelledby="promo-heading">
  <div class="container">
    <header class="section-header">
      <h2 id="promo-heading">โปรพนันออนไลน์คุ้มทุกวัน โบนัสใช้ได้จริง</h2>
      <div class="gold-line"></div>
    </header>
    <p class="section-desc">ที่ TEMO888 โปรโมชันถูกออกแบบให้ใช้งานง่ายและคุ้มกับผู้เล่นจริง ไม่ว่าจะเป็นโบนัสฝากแรก รีโหลดรายวัน คืนยอดเสีย หรือกิจกรรมสะสมแต้ม ครอบคลุมสล็อต บาคาร่า คาสิโนสด และพนันออนไลน์ยอดนิยม เงื่อนไขชัดเจน กดรับผ่านมือถือได้สะดวก</p>

    <div class="promo-carousel" aria-label="สไลด์โปรโมชั่น" role="region">
      <div class="promo-carousel-track" id="promo-track">
        {promos.map(({ alt, src }, i) => (
          <a
            href={externalLink}
            class="promo-carousel-slide"
            aria-label={alt}
            data-index={i}
          >
            <img src={src} alt={alt} width={previewWidth} height={previewHeight} loading="lazy" decoding="async" />
          </a>
        ))}
      </div>
    </div>

    <div style="text-align:center;margin-top:2.5rem">
      <a href="/promotions/" class="btn btn-outline-gold btn-lg">ดูโปรโมชั่นทั้งหมด →</a>
    </div>
  </div>
</section>

<style>
.promo-carousel {
  overflow: hidden;
  border-radius: var(--radius-lg);
}

.promo-carousel-track {
  display: flex;
  transition: transform 0.5s ease;
  will-change: transform;
}

.promo-carousel-slide {
  flex: 0 0 100%;
  width: 100%;
  display: block;
}

.promo-carousel-slide img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: var(--radius-lg);
}
</style>

<script>
(function () {
  const track = document.getElementById("promo-track");
  if (!track) return;

  const total = track.querySelectorAll(".promo-carousel-slide").length;
  if (total === 0) return;

  let current = 0;
  let timer: ReturnType<typeof setInterval>;

  function goTo(index: number) {
    current = (index + total) % total;
    track!.style.transform = `translateX(-${current * 100}%)`;
  }

  function start() {
    timer = setInterval(() => goTo(current + 1), 3000);
  }

  function stop() {
    clearInterval(timer);
  }

  track.addEventListener("touchstart", stop, { passive: true });
  track.addEventListener("touchend", () => { goTo(current); start(); }, { passive: true });

  start();
})();
</script>
