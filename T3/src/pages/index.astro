---
import BaseLayout from "@/layouts/BaseLayout.astro";
import Banner from "@/components/Banner.astro";
import Hero from "@/components/Hero.astro";
import GameSection from "@/components/GameSection.astro";
import SeoSection from "@/components/SeoSection.astro";
import Promotion from "@/components/Promotion.astro";
import Provider from "@/components/Provider.astro";
import Cta from "@/components/Cta.astro";
import { SITE, EXTERNAL_LINK } from "@/config/site";
import { getMainSeoHeading, getMainSeoDescription } from "@/lib/seo-content";
import { BANNER, getLogoSrc } from "@/lib/images";

const mainSeo = getMainSeoHeading();
const pageDescription = getMainSeoDescription();

const indexKeywords: string[] = [];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Organization",
  name: SITE.name,
  url: SITE.url,
  logo: `${SITE.url}${getLogoSrc()}`,
  description: pageDescription,
  contactPoint: {
    "@type": "ContactPoint",
    contactType: "customer service",
    availableLanguage: "Thai",
  },
};
---

<BaseLayout
  title={`${SITE.name} | ${mainSeo}`}
  description={pageDescription}
  keywords={[SITE.name, ...indexKeywords].join(", ")}
  ogType="website"
  jsonLd={jsonLd}
  preloadImage={BANNER.src}
>
  <Banner />
  <Hero externalLink={EXTERNAL_LINK} />
  <GameSection externalLink={EXTERNAL_LINK} />
  <Provider />
  <SeoSection externalLink={EXTERNAL_LINK} />
  <Promotion externalLink={EXTERNAL_LINK} />
  <Cta externalLink={EXTERNAL_LINK} />
</BaseLayout>
