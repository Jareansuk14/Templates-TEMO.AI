---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE, BRAND_NAME, LINE } from "@/config/site";
import { getContactSeoHeading, getContactSeoDescription } from "@/lib/seo-content";
import { LINE_QR } from "@/lib/images";

const contactSeo = getContactSeoHeading();
const pageDescription = getContactSeoDescription();

const contactKeywords: string[] = [];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  name: `ติดต่อเรา — ${SITE.name}`,
  url: `${SITE.url}/contact/`,
  description: pageDescription,
};
---

<BaseLayout
  title={`ติดต่อเรา ${SITE.name} | ${contactSeo}`}
  description={pageDescription}
  keywords={[SITE.name, ...contactKeywords].join(", ")}
  jsonLd={jsonLd}
>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">หน้าแรก</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <span aria-current="page">ติดต่อเรา</span>
      </nav>
      <h1 id="contact-seo"><span class="section-brand">{BRAND_NAME}</span>ติดต่อบริการลูกค้า แชทสด LINE ภาษาไทย ตอบไว ตลอด 24 ชั่วโมง</h1>
      <p id="sub-contact-seo">ศูนย์ช่วยเหลือของ WINTERS789 พร้อมบริการตลอด 24 ชั่วโมง ผ่านแชทสดและไลน์ภาษาไทย เจ้าหน้าที่ให้คำแนะนำตั้งแต่ขั้นตอนสมัคร ยืนยันตัวตน ตั้งค่าความปลอดภัย ฝากถอนออโต้ ไปจนถึงการแก้ปัญหาเฉพาะหน้าแบบเรียลไทม์ เอกสารความรู้และคำถามพบบ่อยช่วยให้มือใหม่เริ่มต้นได้เร็ว รองรับทุกอุปกรณ์ทั้งมือถือและคอมพิวเตอร์ ผู้เล่นสามารถสอบถามข้อมูลโปรโมชัน เงื่อนไขโบนัส ประวัติธุรกรรม หรือวิธีจัดการงบประมาณอย่างมีวินัยได้ตลอดเวลา การเดิมพันผ่านเว็บตรงช่วยลดความเสี่ยง และให้คุณเข้าถึง คาสิโนออนไลน์ สล็อต บาคาร่า แทงบอล ได้ในบัญชีเดียว ข้อมูลลูกค้าทุกส่วนถูกเข้ารหัสและเก็บรักษาตามมาตรฐาน เพื่อให้ทุกคลิกปลอดภัย มั่นใจ และต่อเนื่อง</p>
    </div>
  </section>

  <!-- LINE CONTACT -->
  <section class="section" aria-labelledby="contact-heading">
    <div class="container">
      <div class="line-card">
        <div class="line-icon" aria-hidden="true">💬</div>
        <h2 id="contact-heading">แอดไลน์ติดต่อเราได้เลย</h2>
        <p>ทีมงานเราพร้อมตอบคุณตลอด 24 ชั่วโมง</p>

        <div class="line-qr">
          <img
            src={LINE_QR.src}
            alt={`QR Code LINE ${LINE.id}`}
            width={LINE_QR.width}
            height={LINE_QR.height}
            loading="lazy"
            decoding="async"
          />
        </div>

        <div class="line-id">{LINE.id}</div>
      </div>
    </div>
  </section>

</BaseLayout>
