---
import { BRAND_NAME } from "@/config/site";
import { ACTION_BUTTONS } from "@/lib/images";

interface Props {
  externalLink: string;
}
const { externalLink } = Astro.props;

const login = ACTION_BUTTONS.login;
const register = ACTION_BUTTONS.register;
---

<!-- HERO CONTENT -->
<section class="hero-below" aria-labelledby="main-seo">
  <div class="container">
    <h1 id="main-seo"><span class="section-brand">{BRAND_NAME}</span>พนันออนไลน์ เว็บตรงครบวงจร คาสิโนออนไลน์ สล็อต บาคาร่า แทงบอล ปลอดภัย ฝากถอนออโต้ รวดเร็ว</h1>
    <p class="hero-desc" id="sub-main-seo">WINTERS789 สร้างมาตรฐานความปลอดภัยระดับสูงด้วยเว็บตรงที่ผ่านการตรวจสอบ โปร่งใส และป้องกันข้อมูลครบวงจร ตั้งแต่การเข้ารหัสหลายชั้น ระบบป้องกันบอท และการยืนยันตัวตนแบบสองขั้น ผู้เล่นเข้าถึง คาสิโนออนไลน์ สล็อต บาคาร่า แทงบอล และกีฬาเสมือน ได้บนทุกอุปกรณ์อย่างลื่นไหล อินเทอร์เฟซใช้งานง่าย ปรับภาษาไทยชัดเจน รองรับโหมดมืดเพื่อถนอมสายตา ระบบฝากถอนออโต้เชื่อมต่อธนาคารและวอลเล็ตหลัก ทำรายการได้ภายในไม่กี่วินาที พร้อมบันทึกประวัติธุรกรรมให้ตรวจสอบตลอดเวลา เริ่มต้นแบบมั่นใจด้วยโหมดทดลองเล่น เครดิตฟรีสำหรับสมาชิกใหม่ และคู่มือพื้นฐานอ่านง่าย ทุกเกมแสดงกติกาและค่า RTP อย่างชัดเจน ช่วยวางแผนงบและกลยุทธ์ได้อย่างมีเหตุผล ทีมงานบริการไทยดูแลตลอด 24 ชั่วโมง อัปเดตโปรโมชันสม่ำเสมอ เงื่อนไขเข้าใจง่าย เพื่อประสบการณ์ พนันออนไลน์ ที่มั่นคง คุ้มค่า และยั่งยืน</p>
    <div class="hero-action-pair">
      <a href={externalLink} class="hero-action-link" aria-label={login.alt}>
        <img src={login.src} alt={login.alt} width={login.width} height={login.height} loading="eager" decoding="async" />
      </a>
      <a href={externalLink} class="hero-action-link" aria-label={register.alt}>
        <img src={register.src} alt={register.alt} width={register.width} height={register.height} loading="eager" decoding="async" />
      </a>
    </div>
  </div>
</section>
