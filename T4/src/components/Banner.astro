---
import { BANNER, hasBannerImage } from "@/lib/images";

const hasBanner = hasBannerImage();
---

<!-- HERO BANNER SECTION -->
<section class="hero-banner-section" aria-label="Hero banner">
  <div class="container">
    {hasBanner && (
      <img
        src={BANNER.src}
        alt={BANNER.alt}
        class="hero-banner-img"
        width={BANNER.width}
        height={BANNER.height}
        loading="eager"
        fetchpriority="high"
        decoding="async"
      />
    )}
  </div>
</section>
