---
import { BRAND_NAME } from "@/config/site";
import { SEO_ARTICLE_IMAGES } from "@/lib/images";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const whySections = [
  { id: "seo-1", heading: "สล็อตออนไลน์ แตกง่าย โบนัสเพียบ จ่ายจริง เว็บตรง ฝากถอนออโต้ RTP รองรับวอลเล็ต", desc: "WINTERS789 รวบรวมเกมสล็อตจากผู้ให้บริการชั้นนำ โดยเน้นความโปร่งใสของค่า RTP ความผันผวน และโครงสร้างเพย์ไลน์ให้ตรวจสอบก่อนเดิมพัน คุณสามารถทดลองเล่นเพื่อทำความเข้าใจจังหวะเกม ฟีเจอร์พิเศษ และการจ่ายในแต่ละรอบ จากนั้นค่อยวางแผนงบแบบเป็นขั้นตอน ระบบฝากถอนออโต้รองรับธนาคารหลักและวอลเล็ต ใช้งานได้เร็ว ปลอดภัย และไม่เสียเวลาเปลี่ยนหน้าจอ หมวดหมู่ค้นหาช่วยแยกแนวทางชัดเจน เช่น คลาสสิก เมกะเวย์ ซื้อฟรีสปิน และแจ็กพอตสะสม มีรีวิวรายละเอียดโบนัส รอบฟรีสปิน และสถิติการเข้ารางวัลอัปเดตสม่ำเสมอ เดิมพันผ่านเว็บตรงที่รวม คาสิโนออนไลน์ สล็อต บาคาร่า แทงบอล ในบัญชีเดียว โปรโมชันรายวัน รายสัปดาห์ และภารกิจสะสมแต้ม เพิ่มโอกาสรับรางวัลอย่างยุติธรรม เหมาะกับทั้งผู้เริ่มต้นและสายทำกำไรระยะยาว" },
  { id: "seo-2", heading: "บาคาร่าออนไลน์สด ภาพคมชัด เว็บตรง ปลอดภัย ระบบออโต้ 24 ชั่วโมง ไม่มีสะดุด รองรับมือถือ", desc: "WINTERS789 ให้บริการบาคาร่าออนไลน์สดผ่านเว็บตรงที่ได้มาตรฐาน ภาพคมชัดดีเลย์ต่ำ ห้องหลากหลายสไตล์ ทั้งสปีด โมเดิร์น และคลาสสิก พร้อมสถิติย้อนหลังและเค้าไพ่แบบเรียลไทม์เพื่อช่วยวิเคราะห์จังหวะเดิมพัน โหมดสาธิตและบทเรียนเบื้องต้นช่วยฝึกอ่านโต๊ะและบริหารงบ ก่อนย้ายไปเล่นเงินจริงอย่างมั่นใจ ระบบฝากถอนออโต้ปลอดภัย รองรับธนาคารชั้นนำและวอลเล็ต ทำรายการได้ตลอด 24 ชั่วโมง อินเทอร์เฟซรองรับมือถือแนวตั้งแนวนอน เปลี่ยนโต๊ะรวดเร็ว ไม่พลาดรอบสำคัญ นอกจากบาคาร่า คุณยังสลับไปเล่น คาสิโนออนไลน์ สล็อต แทงบอล และเกมคาสิโนสดอื่นๆ ได้ทันทีในบัญชีเดียว เงื่อนไขโปรโมชันโปร่งใส แจ้งชัดเจน ตรวจสอบยอดรับ ยอดคืน และบันทึกการเดิมพันได้ครบถ้วน ช่วยให้การวางแผนเป็นระบบ" },
  { id: "seo-3", heading: "แทงบอลออนไลน์ ครบทุกลีก ราคาดี เว็บตรง สถิติสด รองรับมือถือ ถ่ายทอดสด บริการไทย ตลอดคืน", desc: "WINTERS789 เปิดรับแทงบอลออนไลน์ครบทุกลีก ตั้งแต่บอลยุโรป บอลเอเชีย ไปจนถึงทัวร์นาเมนต์พิเศษ พร้อมราคาน้ำที่อัปเดตแบบเรียลไทม์และประเภทบิลหลากหลาย เช่น เต็มเวลา สูงต่ำ สเต็ป และบอลสด หน้าจอสถิติสด แผนผังการเล่น และฟีดถ่ายทอดคุณภาพสูงช่วยให้ตัดสินใจแม่นยำ ระบบเว็บตรงเสถียร ฝากถอนออโต้รองรับธนาคารและวอลเล็ต ทำรายการได้ตลอดวัน รองรับมือถือและแท็บเล็ต อินเทอร์เฟซอ่านง่าย ปรับโหมดมืดได้ เชื่อมต่อศูนย์ช่วยเหลือภาษาไทย 24 ชั่วโมง ในบัญชีเดียวคุณยังเข้าถึง คาสิโนออนไลน์ สล็อต บาคาร่า และเกมกีฬาอื่นๆ ได้ทันที เงื่อนไขโปรโมชันโปร่งใส ตรวจสอบยอดคืนและประวัติการเดิมพันได้ชัดเจน ช่วยวางงบประมาณอย่างมั่นใจ" },
];
---

<!-- Images: no glass, raw 3-col grid -->
<div class="seo-imgs-strip">
  {whySections.map(({ id }) => {
    const image = SEO_ARTICLE_IMAGES[id];
    return <a href={externalLink} class="seo-img-link" aria-label={image.alt} id={id}><img src={image.src} alt={image.alt} width={image.width} height={image.height} loading="lazy" decoding="async" /></a>;
  })}
</div>

<!-- Articles: 3 separate glass boxes side-by-side on desktop -->
<div class="seo-arts-strip">
  {whySections.map(({ id, heading, desc }) => (
    <article class="seo-art-box" aria-labelledby={`${id}-title`}>
      <h2 id={`${id}-title`}><span class="section-brand">{BRAND_NAME}</span>{heading}</h2>
      <p id={`sub-${id}`}>{desc}</p>
    </article>
  ))}
</div>
