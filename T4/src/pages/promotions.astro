---
import BaseLayout from "@/layouts/BaseLayout.astro";
import { SITE, BRAND_NAME, EXTERNAL_LINK } from "@/config/site";
import { getPromotionSeoHeading, getPromotionSeoDescription } from "@/lib/seo-content";
import { PROMOS } from "@/lib/images";

const promotionSeo = getPromotionSeoHeading();
const pageDescription = getPromotionSeoDescription();

const promoKeywords: string[] = [];

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "ItemList",
  name: `โปรโมชั่น ${SITE.name}`,
  description: pageDescription,
  url: `${SITE.url}/promotions/`,
  numberOfItems: PROMOS.length,
};
---

<BaseLayout
  title={`โปรโมชั่น ${SITE.name} | ${promotionSeo}`}
  description={pageDescription}
  keywords={[SITE.name, ...promoKeywords].join(", ")}
  jsonLd={jsonLd}
>

  <!-- PAGE HEADER -->
  <section class="page-header">
    <div class="container">
      <nav class="breadcrumb" aria-label="Breadcrumb">
        <a href="/">หน้าแรก</a>
        <span class="breadcrumb-sep" aria-hidden="true">/</span>
        <span aria-current="page">โปรโมชั่น</span>
      </nav>
      <h1 id="promotion-seo"><span class="section-brand">{BRAND_NAME}</span>โปรโมชั่นคาสิโนออนไลน์ โบนัสแรง คืนยอดเสีย รายวัน สมาชิกใหม่คุ้ม เงื่อนไขโปร่งใส เชิญเพื่อนได้ รับของรางวัล</h1>
      <p id="sub-promotion-seo">โปรโมชัน WINTERS789 ถูกออกแบบให้เข้าใจง่ายและปรับใช้ได้จริง ตั้งแต่โบนัสต้อนรับ เครดิตทดลองเล่น ไปจนถึงกิจกรรมรายวัน รายสัปดาห์ และโปรคืนยอดตามระดับสมาชิก เงื่อนไขระบุเป็นข้อชัดเจน เลือกรับหรือปฏิเสธได้อิสระเพื่อให้เหมาะกับสไตล์การเล่นของคุณ ระบบเว็บตรงคำนวณโบนัสอัตโนมัติและลงบัญชีอย่างโปร่งใส ตรวจสอบในประวัติธุรกรรมได้ทันที ผู้เล่น คาสิโนออนไลน์ สล็อต บาคาร่า และแทงบอล ได้รับข้อเสนอแยกตามหมวดเกม เพิ่มความคุ้มค่าโดยไม่ซับซ้อน มีโปรชวนเพื่อนพร้อมค่าตอบแทนต่อเนื่อง และโปรวีไอพีที่มาพร้อมของรางวัล รายการพิเศษ และผู้จัดการบัญชีเฉพาะทาง ทุกอย่างทำงานผ่านระบบออโต้ ปลอดภัย รวดเร็ว และเป็นธรรม</p>
    </div>
  </section>

  <section class="section">
    <div class="container">
      <div class="promo-grid-5">
        {PROMOS.map(({ src, alt, width, height }, i) => (
          <a
            href={EXTERNAL_LINK}
            class="promo-full-card"
            aria-label={alt}
          >
            <img
              src={src}
              alt={alt}
              width={width}
              height={height}
              loading={i < 2 ? "eager" : "lazy"}
              decoding="async"
            />
          </a>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>
