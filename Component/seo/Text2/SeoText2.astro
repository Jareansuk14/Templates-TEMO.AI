---
const whySections = [
  { id: "seo-1", heading: "สล็อต เว็บตรง แตกหนัก RTP ชัด โบนัสจัดเต็ม ฝากถอนออโต้ รองรับวอลเล็ต จ่ายไว", desc: "ที่ TEMO888 คุณจะพบสล็อตจากค่ายชั้นนำพร้อมข้อมูลสำคัญครบ เช่น RTP ช่วงความผันผวน จำนวนเพย์ไลน์ และฟีเจอร์พิเศษ ตรวจสอบได้ก่อนหมุนจริง ลองเล่นโหมดเดโมเพื่อจับจังหวะและวางแผนงบอย่างมีวินัย จากนั้นค่อยปรับเบทตามกลยุทธ์ ฝากถอนออโต้ผ่านธนาคารและวอลเล็ต ทำรายการเร็ว ปลอดภัย และไม่เด้งออกจากหน้าเกม แยกหมวดชัดเจนทั้งคลาสสิก เมกะเวย์ ซื้อฟรีสปิน และแจ็กพอตสะสม หนึ่งบัญชีเชื่อม คาสิโนออนไลน์ สล็อต บาคาร่า แทงบอล บนเว็บตรง โปรรายวัน ภารกิจ และสะสมแต้มช่วยต่อยอดกำไร" },
  { id: "seo-2", heading: "บาคาร่าสด เว็บตรง คมชัดไม่หน่วง เล่นได้ 24 ชม. มือถือสะดวก ระบบออโต้ ปลอดภัยสูง", desc: "TEMO888 บริการบาคาร่าสดผ่านเว็บตรง ภาพคมชัด หน่วงต่ำ มีห้องให้เลือกทั้งสปีด คลาสสิก และโมเดิร์น พร้อมสถิติย้อนหลังและเค้าไพ่แบบเรียลไทม์ช่วยวิเคราะห์เดิมพัน มือใหม่เริ่มจากโหมดสาธิตและบทเรียนพื้นฐานได้ก่อน ฝากถอนออโต้ปลอดภัย รองรับธนาคารและวอลเล็ต 24 ชม. อินเทอร์เฟซมือถือแนวตั้ง-แนวนอน เปลี่ยนโต๊ะได้รวดเร็ว บัญชีเดียวสลับไปยัง คาสิโนออนไลน์ สล็อต หรือ แทงบอล ได้ทันที โปรโมชันระบุเงื่อนไขชัด ตรวจสอบยอดรับ ยอดคืน และประวัติการเล่นได้ครบ" },
];
---

{whySections.map(({ id, heading, desc }) => (
  <section id={id} class="seo-text-section" aria-labelledby={`${id}-title`}>
    <div class="container">
      <h2 id={`${id}-title`} class="seo-text-heading">
        {heading}
      </h2>
      <p id={`sub-${id}`} class="seo-text-desc">{desc}</p>
    </div>
  </section>
))}
