---
import { SEO_ARTICLE_IMAGES, PLAY_BUTTON } from "@/lib/images";
import { SEO } from "@/data/content/seo";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const [first, second] = SEO.slice(0, 2);
const image = SEO_ARTICLE_IMAGES[first.id];
---

<div class="seo-bdp">
  <div class="seo-bdp-grid">
    <div class="seo-bdp-box">
      <article class="seo-bdp-block" aria-labelledby={`${first.id}-title`}>
        <h2 id={`${first.id}-title`}>{first.heading}</h2>
        <p id={`sub-${first.id}`}>{first.desc}</p>
      </article>
      <article class="seo-bdp-block" aria-labelledby={`${second.id}-title`}>
        <h2 id={`${second.id}-title`}>{second.heading}</h2>
        <p id={`sub-${second.id}`}>{second.desc}</p>
      </article>
    </div>
    <div class="seo-bdp-media">
      <a href={externalLink} class="seo-bdp-img" aria-label={image.alt} id={first.id}>
        <img src={image.src} alt={image.alt} width={image.width} height={image.height} loading="lazy" decoding="async" />
      </a>
      <div class="seo-play">
        <a href={externalLink} aria-label="เล่นเกม">
          <img src={PLAY_BUTTON.src} alt="" width={PLAY_BUTTON.width} height={PLAY_BUTTON.height} loading="lazy" decoding="async" />
        </a>
      </div>
    </div>
  </div>
</div>
