---
import { SEO_ARTICLE_IMAGES, SEO_MASCOT } from "@/lib/images";
import { SEO } from "@/data/content/seo";
import { BRAND_NAME, SITE_THEME } from "@/config/site";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const bullets = SEO.slice(0, 3);
const paragraph = SEO[3];
const bottomImage = { ...SEO_ARTICLE_IMAGES["seo-1"], id: "seo-1" };
---

<div class="seo-s4t">
  <div class="seo-s4t-top">
    <div class="seo-s4t-mascot">
      <img src={SEO_MASCOT.src} alt={SEO_MASCOT.alt} width={SEO_MASCOT.width} height={SEO_MASCOT.height} loading="lazy" decoding="async" />
    </div>
    <ol class="seo-s4t-timeline" aria-hidden="true">
      {bullets.map(() => (
        <li><span class="seo-s4t-timeline-dot"></span></li>
      ))}
    </ol>
    <ul class="seo-s4t-bullets">
      {bullets.map(({ id, heading, desc }) => (
        <li>
          <div class="seo-s4t-bullet" id={id}>
            <span class="seo-s4t-bullet-body">
              <span class="seo-s4t-bullet-title">{heading}</span>
              <span class="seo-s4t-bullet-desc">{desc}</span>
            </span>
          </div>
        </li>
      ))}
    </ul>
  </div>

  <div class="seo-s4t-divider"><span>{BRAND_NAME} {SITE_THEME} อันดับ 1</span></div>

  <div class="seo-s4t-row">
    <article class="seo-s4t-art" aria-labelledby="seo-s4t-title">
      <h2 id="seo-s4t-title">{paragraph.heading}</h2>
      <p>{paragraph.desc}</p>
    </article>
    <a href={externalLink} class="seo-s4t-img" aria-label={bottomImage.alt}>
      <img src={bottomImage.src} alt={bottomImage.alt} width={bottomImage.width} height={bottomImage.height} loading="lazy" decoding="async" />
    </a>
  </div>
</div>
