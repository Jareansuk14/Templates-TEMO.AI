---
import { SEO_ARTICLE_IMAGES, PLAY_BUTTON } from "@/lib/images";
import { SEO } from "@/data/content/seo";
import { BRAND_NAME, SITE_THEME } from "@/config/site";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const [first, second, third] = SEO.slice(0, 3);
const topImage = SEO_ARTICLE_IMAGES[first.id];
const midImage = SEO_ARTICLE_IMAGES[second.id];
const bottomImage = SEO_ARTICLE_IMAGES[third.id];
---

<div class="seo-bps3">
  <div class="seo-bps3-grid">
    <div class="seo-bps3-box">
      <article class="seo-bps3-block" aria-labelledby={`${first.id}-title`}>
        <h2 id={`${first.id}-title`}>{first.heading}</h2>
        <p id={`sub-${first.id}`}>{first.desc}</p>
      </article>
      <div class="seo-bps3-play seo-play">
        <a href={externalLink} aria-label="เล่นเกม">
          <img src={PLAY_BUTTON.src} alt="" width={PLAY_BUTTON.width} height={PLAY_BUTTON.height} loading="lazy" decoding="async" />
        </a>
      </div>
      <article class="seo-bps3-block" aria-labelledby={`${second.id}-title`}>
        <h2 id={`${second.id}-title`}>{second.heading}</h2>
        <p id={`sub-${second.id}`}>{second.desc}</p>
      </article>
    </div>

    <a href={externalLink} class="seo-bps3-img seo-bps3-img--top" aria-label={topImage.alt} id={first.id}>
      <img src={topImage.src} alt={topImage.alt} width={topImage.width} height={topImage.height} loading="lazy" decoding="async" />
    </a>

    <a href={externalLink} class="seo-bps3-img seo-bps3-img--bottom" aria-label={midImage.alt} id={second.id}>
      <img src={midImage.src} alt={midImage.alt} width={midImage.width} height={midImage.height} loading="lazy" decoding="async" />
    </a>
  </div>

  <div class="seo-bps3-divider"><span>{BRAND_NAME} {SITE_THEME} อันดับ 1</span></div>

  <div class="seo-bps3-foot">
    <a href={externalLink} class="seo-bps3-img seo-bps3-img--foot" aria-label={bottomImage.alt} id={third.id}>
      <img src={bottomImage.src} alt={bottomImage.alt} width={bottomImage.width} height={bottomImage.height} loading="lazy" decoding="async" />
    </a>
    <article class="seo-bps3-plain" aria-labelledby={`${third.id}-title`}>
      <h2 id={`${third.id}-title`}>{third.heading}</h2>
      <p id={`sub-${third.id}`}>{third.desc}</p>
    </article>
  </div>
</div>
