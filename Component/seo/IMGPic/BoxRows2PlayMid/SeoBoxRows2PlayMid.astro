---
import { SEO_ARTICLE_IMAGES, PLAY_BUTTON, SEO_MASCOT } from "@/lib/images";
import { SEO } from "@/data/content/seo";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const [first, second] = SEO.slice(0, 2);
const firstImage = SEO_ARTICLE_IMAGES[first.id];
const secondImage = SEO_ARTICLE_IMAGES[second.id];
---

<div class="seo-br2pm">
  <div class="seo-br2pm-row seo-br2pm-row--start">
    <article class="seo-br2pm-copy" aria-labelledby={`${first.id}-title`}>
      <h2 id={`${first.id}-title`}>{first.heading}</h2>
      <p id={`sub-${first.id}`}>{first.desc}</p>
    </article>
    <a href={externalLink} class="seo-br2pm-img" aria-label={firstImage.alt} id={first.id}>
      <img src={firstImage.src} alt={firstImage.alt} width={firstImage.width} height={firstImage.height} loading="lazy" decoding="async" />
    </a>
  </div>

  <div class="seo-br2pm-hero">
    <div class="seo-br2pm-mascot">
      <img src={SEO_MASCOT.src} alt={SEO_MASCOT.alt} width={SEO_MASCOT.width} height={SEO_MASCOT.height} loading="lazy" decoding="async" />
    </div>
    <div class="seo-play">
      <a href={externalLink} aria-label="เล่นเกม">
        <img src={PLAY_BUTTON.src} alt="" width={PLAY_BUTTON.width} height={PLAY_BUTTON.height} loading="lazy" decoding="async" />
      </a>
    </div>
  </div>

  <div class="seo-br2pm-row seo-br2pm-row--reverse seo-br2pm-row--end">
    <article class="seo-br2pm-copy" aria-labelledby={`${second.id}-title`}>
      <h2 id={`${second.id}-title`}>{second.heading}</h2>
      <p id={`sub-${second.id}`}>{second.desc}</p>
    </article>
    <a href={externalLink} class="seo-br2pm-img" aria-label={secondImage.alt} id={second.id}>
      <img src={secondImage.src} alt={secondImage.alt} width={secondImage.width} height={secondImage.height} loading="lazy" decoding="async" />
    </a>
  </div>
</div>
