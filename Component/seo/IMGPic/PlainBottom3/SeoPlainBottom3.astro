---
import { SEO_ARTICLE_IMAGES } from "@/lib/images";
import { SEO } from "@/data/content/seo";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const first = SEO[0];
const second = SEO[1];
const third = SEO[2];
const topImage = SEO_ARTICLE_IMAGES["seo-1"];
const midImage = SEO_ARTICLE_IMAGES["seo-2"];
const heroImage = SEO_ARTICLE_IMAGES["seo-3"];
---

<div class="seo-pb3">
  {(first || topImage) && (
    <div class="seo-pb3-row">
      {first && (
        <article class="seo-pb3-copy" aria-labelledby={`${first.id}-title`}>
          <h2 id={`${first.id}-title`}>{first.heading}</h2>
          <p id={`sub-${first.id}`}>{first.desc}</p>
        </article>
      )}
      {topImage && (
        <a href={externalLink} class="seo-pb3-img" aria-label={topImage.alt} id="seo-1">
          <img src={topImage.src} alt={topImage.alt} width={topImage.width} height={topImage.height} loading="lazy" decoding="async" />
        </a>
      )}
    </div>
  )}

  {(midImage || second) && (
    <div class="seo-pb3-row">
      {midImage && (
        <a href={externalLink} class="seo-pb3-img" aria-label={midImage.alt} id="seo-2">
          <img src={midImage.src} alt={midImage.alt} width={midImage.width} height={midImage.height} loading="lazy" decoding="async" />
        </a>
      )}
      {second && (
        <article class="seo-pb3-copy seo-pb3-copy--end" aria-labelledby={`${second.id}-title`}>
          <h2 id={`${second.id}-title`}>{second.heading}</h2>
          <p id={`sub-${second.id}`}>{second.desc}</p>
        </article>
      )}
    </div>
  )}

  {heroImage && (
    <a href={externalLink} class="seo-pb3-hero" aria-label={heroImage.alt} id="seo-3">
      <img src={heroImage.src} alt={heroImage.alt} width={heroImage.width} height={heroImage.height} loading="lazy" decoding="async" />
    </a>
  )}

  {third && (
    <article class="seo-pb3-foot" aria-labelledby={`${third.id}-title`}>
      <h2 id={`${third.id}-title`}>{third.heading}</h2>
      <p id={`sub-${third.id}`}>{third.desc}</p>
    </article>
  )}
</div>
