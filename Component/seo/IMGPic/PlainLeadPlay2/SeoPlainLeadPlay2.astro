---
import { SEO_ARTICLE_IMAGES, PLAY_BUTTON, SEO_MASCOT } from "@/lib/images";
import { SEO } from "@/data/content/seo";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const first = SEO[0];
const second = SEO[1];
const topImage = SEO_ARTICLE_IMAGES["seo-1"];
---

<div class="seo-plp2">
  {(topImage || first) && (
    <div class="seo-plp2-row">
      {topImage && (
        <a href={externalLink} class="seo-plp2-img" aria-label={topImage.alt} id="seo-1">
          <span class="seo-plp2-img-inner">
            <img src={topImage.src} alt={topImage.alt} width={topImage.width} height={topImage.height} loading="lazy" decoding="async" />
          </span>
        </a>
      )}
      {first && (
        <article class="seo-plp2-copy" aria-labelledby={`${first.id}-title`}>
          <h2 id={`${first.id}-title`}>{first.heading}</h2>
          <p id={`sub-${first.id}`}>{first.desc}</p>
        </article>
      )}
    </div>
  )}

  <div class="seo-plp2-body">
    <div class="seo-plp2-side">
      <div class="seo-play">
        <a href={externalLink} aria-label="เล่นเกม">
          <img src={PLAY_BUTTON.src} alt="" width={PLAY_BUTTON.width} height={PLAY_BUTTON.height} loading="lazy" decoding="async" />
        </a>
      </div>

      {second && (
        <article class="seo-plp2-copy" aria-labelledby={`${second.id}-title`}>
          <h2 id={`${second.id}-title`}>{second.heading}</h2>
          <p id={`sub-${second.id}`}>{second.desc}</p>
        </article>
      )}
    </div>

    <div class="seo-plp2-mascot">
      <img src={SEO_MASCOT.src} alt={SEO_MASCOT.alt} width={SEO_MASCOT.width} height={SEO_MASCOT.height} loading="lazy" decoding="async" />
    </div>
  </div>
</div>
