---
import { SEO_ARTICLE_IMAGES } from "@/lib/images";
import { SEO } from "@/data/content/seo";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;
---

<section class="seo-cards" aria-label="ข้อมูลเด่น">
  <div class="container seo-cards-grid">
    {SEO.map(({ id, heading, desc }) => {
      const image = SEO_ARTICLE_IMAGES[id];
      return (
        <article class="seo-card" aria-labelledby={`${id}-title`}>
          {image && (
            <a href={externalLink} class="seo-card-img" aria-label={image.alt} id={id}>
              <img src={image.src} alt={image.alt} width={image.width} height={image.height} loading="lazy" decoding="async" />
            </a>
          )}
          <div class="seo-card-body">
            <h2 id={`${id}-title`}>{heading}</h2>
            <p id={`sub-${id}`}>{desc}</p>
          </div>
        </article>
      );
    })}
  </div>
</section>
