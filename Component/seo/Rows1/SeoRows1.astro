---
import { SEO_ARTICLE_IMAGES } from "@/lib/images";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const whySections = [
  { id: "seo-1", heading: "สล็อต เว็บตรง แตกหนัก RTP ชัด โบนัสจัดเต็ม ฝากถอนออโต้ รองรับวอลเล็ต จ่ายไว", desc: "ที่ TEMO888 คุณจะพบสล็อตจากค่ายชั้นนำพร้อมข้อมูลสำคัญครบ เช่น RTP ช่วงความผันผวน จำนวนเพย์ไลน์ และฟีเจอร์พิเศษ ตรวจสอบได้ก่อนหมุนจริง ลองเล่นโหมดเดโมเพื่อจับจังหวะและวางแผนงบอย่างมีวินัย จากนั้นค่อยปรับเบทตามกลยุทธ์ ฝากถอนออโต้ผ่านธนาคารและวอลเล็ต ทำรายการเร็ว ปลอดภัย และไม่เด้งออกจากหน้าเกม แยกหมวดชัดเจนทั้งคลาสสิก เมกะเวย์ ซื้อฟรีสปิน และแจ็กพอตสะสม หนึ่งบัญชีเชื่อม คาสิโนออนไลน์ สล็อต บาคาร่า แทงบอล บนเว็บตรง โปรรายวัน ภารกิจ และสะสมแต้มช่วยต่อยอดกำไร" },
];
---

<div class="seo-rows">
  {whySections.map(({ id, heading, desc }, index) => {
    const image = SEO_ARTICLE_IMAGES[id];
    const isEven = index % 2 === 1;
    return (
      <div class={`seo-row${isEven ? " seo-row--reverse" : ""}`}>
        <a href={externalLink} class="seo-img-link" aria-label={image.alt} id={id}>
          <img src={image.src} alt={image.alt} width={image.width} height={image.height} loading="lazy" decoding="async" />
        </a>
        <article class="seo-art-box" aria-labelledby={`${id}-title`}>
          <h2 id={`${id}-title`}>{heading}</h2>
          <p id={`sub-${id}`}>{desc}</p>
        </article>
      </div>
    );
  })}
</div>
