---
import { BRAND_NAME } from "@/config/site";
import { ACTION_BUTTONS } from "@/lib/images";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const login = ACTION_BUTTONS.login;
const register = ACTION_BUTTONS.register;
---

<section class="hero-below cta-section" aria-labelledby="cta-seo">
  <div class="container">
    <h2 id="cta-seo"><span class="section-brand">{BRAND_NAME}</span>สมัครเว็บตรงวันนี้ รับเครดิตฟรี เริ่มเล่นคาสิโนออนไลน์ทันที ปลอดภัย คุ้มทุกบิล</h2>
    <p class="hero-desc cta-desc" id="sub-cta-seo">สมัครสมาชิกกับ TEMO888 ใช้เวลาไม่กี่นาที ยืนยันตัวตนสองขั้นเพื่อความปลอดภัย แล้วรับโบนัสต้อนรับและเครดิตฟรีทดลองทันที ฝากถอนออโต้ผ่านธนาคารหรือวอลเล็ตได้ตลอดวัน บัญชีเดียวเล่นพนันออนไลน์ครบวงจรทั้ง คาสิโนออนไลน์ สล็อต บาคาร่า แทงบอล และกีฬาเสมือน มีคู่มือเริ่มต้นและระบบช่วยเหลือภาษาไทยคลิกเดียวถึง เงื่อนไขโปรโมชันอ่านง่าย เลือกรับได้เอง เริ่มตอนนี้เพื่อความคุ้มค่าที่จับต้องได้</p>
    <div class="hero-action-pair">
      <a href={externalLink} class="hero-action-link" aria-label={login.alt}>
        <img src={login.src} alt={login.alt} width={login.width} height={login.height} loading="lazy" decoding="async" />
      </a>
      <a href={externalLink} class="hero-action-link" aria-label={register.alt}>
        <img src={register.src} alt={register.alt} width={register.width} height={register.height} loading="lazy" decoding="async" />
      </a>
    </div>
  </div>
</section>
