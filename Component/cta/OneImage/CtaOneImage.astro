---
import { ACTION_BUTTONS } from "@/lib/images";
import { CTA } from "@/data/content/cta";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;
const { contact } = ACTION_BUTTONS;
---

<section class="cta-left" aria-labelledby="cta-seo">
  <div class="container cta-left-inner">
    <h2 id="cta-seo">{CTA.heading}</h2>
    <p id="sub-cta-seo">{CTA.description}</p>
    <div class="cta-left-action">
      <a href={externalLink} aria-label={contact.alt}>
        <img src={contact.src} alt={contact.alt} width={contact.width} height={contact.height} loading="lazy" decoding="async" />
      </a>
    </div>
  </div>
</section>
