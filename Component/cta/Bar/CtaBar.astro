---
import { ACTION_BUTTONS } from "@/lib/images";
import { CTA } from "@/data/content/cta";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;
const { register } = ACTION_BUTTONS;
---

<section class="cta-bar" aria-labelledby="cta-seo">
  <div class="container cta-bar-inner">
    <div class="cta-bar-text">
      <h2 id="cta-seo">{CTA.heading}</h2>
      <p id="sub-cta-seo">{CTA.description}</p>
    </div>
    <a class="cta-bar-btn" href={externalLink} aria-label={register.alt}>
      <img src={register.src} alt={register.alt} width={register.width} height={register.height} loading="lazy" decoding="async" />
    </a>
  </div>
</section>
