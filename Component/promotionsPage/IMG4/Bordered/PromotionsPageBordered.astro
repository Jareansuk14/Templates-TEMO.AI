---
import { EXTERNAL_LINK } from "@/config/site";
import { PROMOTIONS_PAGE } from "@/data/content/promotionsPage";
import { getPromoPreview } from "@/lib/images";

const promos = getPromoPreview(4);
---

<section class="ppg-bd-head">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">หน้าแรก</a><span class="breadcrumb-sep" aria-hidden="true">/</span><span aria-current="page">โปรโมชั่น</span></nav>
    <h1 id="promotion-seo">{PROMOTIONS_PAGE.heading}</h1>
    <p id="sub-promotion-seo">{PROMOTIONS_PAGE.description}</p>
  </div>
</section>

<section class="ppg-bd">
  <div class="container ppg-bd-grid">
    {promos.map(({ src, alt, width, height }) => (
      <a href={EXTERNAL_LINK} class="ppg-bd-card" aria-label={alt}>
        <span class="ppg-bd-inner"><img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" /></span>
      </a>
    ))}
  </div>
</section>

<style>
.ppg-bd-head { padding: 2rem var(--container-pad) 1rem; text-align: center; }
.ppg-bd-head h1 { color: var(--color-text); font-size: var(--fz-page-title); margin: 0.75rem 0 0.5rem; }
.ppg-bd-head p { color: var(--color-text-muted); font-size: var(--fz-body); line-height: var(--lh-body); max-width: 760px; margin-inline: auto; }
.ppg-bd { padding: 1rem var(--container-pad) 2.5rem; }
.ppg-bd-grid { max-width: var(--container-max); margin-inline: auto; display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; }
.ppg-bd-card { display: block; padding: 5px; border-radius: var(--radius-lg); background: linear-gradient(135deg, var(--color-accent), var(--color-primary)); }
.ppg-bd-inner { display: block; border-radius: calc(var(--radius-lg) - 3px); overflow: hidden; background: var(--color-bg); }
.ppg-bd-inner img { width: 100%; height: auto; display: block; }
@media (max-width: 640px) { .ppg-bd-grid { grid-template-columns: 1fr; } }
</style>
