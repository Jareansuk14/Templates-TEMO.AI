---
import { EXTERNAL_LINK } from "@/config/site";
import { PROMOTIONS_PAGE } from "@/data/content/promotionsPage";
import { getPromoPreview } from "@/lib/images";

const promos = getPromoPreview(4);
const topHero = promos[0];
const mids = promos.slice(1, 3);
const bottomHero = promos[3];
---

<section class="ppg-fsp-head">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">หน้าแรก</a><span class="breadcrumb-sep" aria-hidden="true">/</span><span aria-current="page">โปรโมชั่น</span></nav>
    <h1 id="promotion-seo">{PROMOTIONS_PAGE.heading}</h1>
    <p id="sub-promotion-seo">{PROMOTIONS_PAGE.description}</p>
  </div>
</section>

<section class="ppg-fsp">
  <div class="container">
    {topHero && (
      <a href={EXTERNAL_LINK} class="ppg-fsp-main" aria-label={topHero.alt}>
        <img src={topHero.src} alt={topHero.alt} width={topHero.width} height={topHero.height} loading="eager" decoding="async" />
      </a>
    )}

    <div class="ppg-fsp-mid">
      {mids.map(({ src, alt, width, height }) => (
        <a href={EXTERNAL_LINK} class="ppg-fsp-card" aria-label={alt}>
          <img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
        </a>
      ))}
    </div>

    {bottomHero && (
      <a href={EXTERNAL_LINK} class="ppg-fsp-main" aria-label={bottomHero.alt}>
        <img src={bottomHero.src} alt={bottomHero.alt} width={bottomHero.width} height={bottomHero.height} loading="lazy" decoding="async" />
      </a>
    )}
  </div>
</section>

<style>
.ppg-fsp-head { padding: 2rem var(--container-pad) 1rem; text-align: center; }
.ppg-fsp-head h1 { color: var(--color-text); font-size: var(--fz-page-title); margin: 0.75rem 0 0.5rem; }
.ppg-fsp-head p { color: var(--color-text-muted); font-size: var(--fz-body); line-height: var(--lh-body); max-width: 760px; margin-inline: auto; }
.ppg-fsp { padding: 1rem var(--container-pad) 2.5rem; }
.ppg-fsp > .container { max-width: var(--container-max); margin-inline: auto; display: flex; flex-direction: column; gap: 1.5rem; }
.ppg-fsp-main img { width: 100%; height: auto; display: block; border-radius: var(--radius-xl); }
.ppg-fsp-mid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
.ppg-fsp-card img { width: 100%; height: auto; display: block; border-radius: var(--radius-md); }
@media (max-width: 768px) { .ppg-fsp-mid { grid-template-columns: 1fr; } }
</style>
