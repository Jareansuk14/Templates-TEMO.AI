---
import { EXTERNAL_LINK } from "@/config/site";
import { PROMOTIONS_PAGE } from "@/data/content/promotionsPage";
import { getPromoPreview } from "@/lib/images";

const promos = getPromoPreview(4);
---

<section class="ppg-mas-head">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">หน้าแรก</a><span class="breadcrumb-sep" aria-hidden="true">/</span><span aria-current="page">โปรโมชั่น</span></nav>
    <h1 id="promotion-seo">{PROMOTIONS_PAGE.heading}</h1>
    <p id="sub-promotion-seo">{PROMOTIONS_PAGE.description}</p>
  </div>
</section>

<section class="ppg-mas">
  <div class="container">
    <div class="ppg-mas-cols">
      {promos.map(({ src, alt, width, height }) => (
        <a href={EXTERNAL_LINK} class="ppg-mas-item" aria-label={alt}>
          <img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
.ppg-mas-head { padding: 2rem var(--container-pad) 1rem; text-align: center; }
.ppg-mas-head h1 { color: var(--color-text); font-size: var(--fz-page-title); margin: 0.75rem 0 0.5rem; }
.ppg-mas-head p { color: var(--color-text-muted); font-size: var(--fz-body); line-height: var(--lh-body); max-width: 760px; margin-inline: auto; }
.ppg-mas { padding: 1rem var(--container-pad) 2.5rem; }
.ppg-mas > .container { max-width: var(--container-max); margin-inline: auto; }
.ppg-mas-cols { column-count: 2; column-gap: 1.5rem; }
.ppg-mas-item { display: block; margin-bottom: 1.5rem; break-inside: avoid; }
.ppg-mas-item:nth-child(2n) { margin-top: 1.5rem; }
.ppg-mas-item img { width: 100%; height: auto; display: block; border-radius: var(--radius-lg); }
@media (max-width: 640px) { .ppg-mas-cols { column-count: 1; } .ppg-mas-item:nth-child(2n) { margin-top: 0; } }
</style>
