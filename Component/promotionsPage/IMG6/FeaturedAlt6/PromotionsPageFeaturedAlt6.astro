---
import { EXTERNAL_LINK } from "@/config/site";
import { PROMOTIONS_PAGE } from "@/data/content/promotionsPage";
import { getPromoPreview } from "@/lib/images";

const promos = getPromoPreview(6);
const topHero = promos[0];
const row2Top = promos.slice(1, 3);
const midHero = promos[3];
const row2Bottom = promos.slice(4, 6);
---

<section class="ppg-fa6-head">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">หน้าแรก</a><span class="breadcrumb-sep" aria-hidden="true">/</span><span aria-current="page">โปรโมชั่น</span></nav>
    <h1 id="promotion-seo">{PROMOTIONS_PAGE.heading}</h1>
    <p id="sub-promotion-seo">{PROMOTIONS_PAGE.description}</p>
  </div>
</section>

<section class="ppg-fa6">
  <div class="container">
    {topHero && (
      <a href={EXTERNAL_LINK} class="ppg-fa6-main" aria-label={topHero.alt}>
        <img src={topHero.src} alt={topHero.alt} width={topHero.width} height={topHero.height} loading="eager" decoding="async" />
      </a>
    )}

    <div class="ppg-fa6-row">
      {row2Top.map(({ src, alt, width, height }) => (
        <a href={EXTERNAL_LINK} class="ppg-fa6-card" aria-label={alt}>
          <img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
        </a>
      ))}
    </div>

    {midHero && (
      <a href={EXTERNAL_LINK} class="ppg-fa6-main" aria-label={midHero.alt}>
        <img src={midHero.src} alt={midHero.alt} width={midHero.width} height={midHero.height} loading="lazy" decoding="async" />
      </a>
    )}

    <div class="ppg-fa6-row">
      {row2Bottom.map(({ src, alt, width, height }) => (
        <a href={EXTERNAL_LINK} class="ppg-fa6-card" aria-label={alt}>
          <img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
        </a>
      ))}
    </div>
  </div>
</section>

<style>
.ppg-fa6-head { padding: 2rem var(--container-pad) 1rem; text-align: center; }
.ppg-fa6-head h1 { color: var(--color-text); font-size: var(--fz-page-title); margin: 0.75rem 0 0.5rem; }
.ppg-fa6-head p { color: var(--color-text-muted); font-size: var(--fz-body); line-height: var(--lh-body); max-width: 760px; margin-inline: auto; }
.ppg-fa6 { padding: 1rem var(--container-pad) 2.5rem; }
.ppg-fa6 > .container { max-width: var(--container-max); margin-inline: auto; display: flex; flex-direction: column; gap: 1.5rem; }
.ppg-fa6-main img { width: 100%; height: auto; display: block; border-radius: var(--radius-xl); }
.ppg-fa6-row { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.25rem; }
.ppg-fa6-card img { width: 100%; height: auto; display: block; border-radius: var(--radius-md); }
@media (max-width: 768px) { .ppg-fa6-row { grid-template-columns: 1fr; } }
</style>
