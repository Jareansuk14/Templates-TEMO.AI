---
import { EXTERNAL_LINK } from "@/config/site";
import { PROMOTIONS_PAGE } from "@/data/content/promotionsPage";
import { getPromoPreview } from "@/lib/images";

const promos = getPromoPreview(6);
---

<section class="ppg-3c-head">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">หน้าแรก</a><span class="breadcrumb-sep" aria-hidden="true">/</span><span aria-current="page">โปรโมชั่น</span></nav>
    <h1 id="promotion-seo">{PROMOTIONS_PAGE.heading}</h1>
    <p id="sub-promotion-seo">{PROMOTIONS_PAGE.description}</p>
  </div>
</section>

<section class="ppg-3c">
  <div class="container ppg-3c-grid">
    {promos.map(({ src, alt, width, height }) => (
      <a href={EXTERNAL_LINK} class="ppg-3c-card" aria-label={alt}>
        <img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
      </a>
    ))}
  </div>
</section>

<style>
.ppg-3c-head { padding: 2rem var(--container-pad) 1rem; text-align: center; }
.ppg-3c-head h1 { color: var(--color-text); font-size: var(--fz-page-title); margin: 0.75rem 0 0.5rem; }
.ppg-3c-head p { color: var(--color-text-muted); font-size: var(--fz-body); line-height: var(--lh-body); max-width: 760px; margin-inline: auto; }
.ppg-3c { padding: 1rem var(--container-pad) 2.5rem; }
.ppg-3c-grid { max-width: var(--container-max); margin-inline: auto; display: grid; grid-template-columns: repeat(3, 1fr); gap: 1.25rem; }
.ppg-3c-card img { width: 100%; height: auto; display: block; border-radius: var(--radius-md); }
@media (max-width: 900px) { .ppg-3c-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 560px) { .ppg-3c-grid { grid-template-columns: 1fr; } }
</style>
