---
import { getPromoPreview } from "@/lib/images";
import { PROMOTION_SECTION } from "@/data/content/promotionSection";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const promos = getPromoPreview(3);
---

<section class="promo-bsr3" aria-labelledby="promo-heading">
  <div class="promo-bsr3-box">
    <h2 id="promo-heading">{PROMOTION_SECTION.heading}</h2>
    <div class="promo-bsr3-row">
      <div class="promo-bsr3-carousel" aria-label="สไลด์โปรโมชั่น" role="region">
        <div class="promo-bsr3-track" id="promo-bsr3-track">
          {promos.map(({ alt, src, width, height }) => (
            <a href={externalLink} class="promo-bsr3-slide" aria-label={alt}>
              <img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
            </a>
          ))}
        </div>
      </div>
      <p id="sub-promo-heading">{PROMOTION_SECTION.description}</p>
    </div>
  </div>
</section>

<style>
.promo-bsr3-carousel {
  overflow: hidden;
  border-radius: var(--radius-lg);
}

.promo-bsr3-track {
  display: flex;
  transition: transform 0.5s ease;
  will-change: transform;
}

.promo-bsr3-slide {
  flex: 0 0 100%;
  width: 100%;
  display: block;
}

.promo-bsr3-slide img {
  width: 100%;
  height: auto;
  display: block;
  border-radius: var(--radius-lg);
}
</style>

<script is:inline>
(function () {
  var track = document.getElementById("promo-bsr3-track");
  if (!track) return;

  var slides = track.querySelectorAll(".promo-bsr3-slide");
  var total = slides.length;
  if (total === 0) return;

  var current = 0;
  var timer;

  function goTo(index) {
    current = (index + total) % total;
    track.style.transform = "translateX(-" + (current * 100) + "%)";
  }

  function start() {
    timer = setInterval(function () { goTo(current + 1); }, 3000);
  }

  function stop() {
    clearInterval(timer);
  }

  track.addEventListener("touchstart", stop, { passive: true });
  track.addEventListener("touchend", function () { goTo(current); start(); }, { passive: true });

  start();
})();
</script>
