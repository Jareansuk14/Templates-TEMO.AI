---
import { getPromoPreview } from "@/lib/images";
import { PROMOTION_SECTION } from "@/data/content/promotionSection";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const [hero, ...rest] = getPromoPreview(3);
---

<section class="promo-st2" aria-labelledby="promo-heading">
  <div class="promo-st2-inner">
    <header class="promo-st2-head">
      <h2 id="promo-heading">{PROMOTION_SECTION.heading}</h2>
      <p id="sub-promo-heading">{PROMOTION_SECTION.description}</p>
    </header>

    {hero && (
      <a href={externalLink} class="promo-st2-hero" aria-label={hero.alt}>
        <img src={hero.src} alt={hero.alt} width={hero.width} height={hero.height} loading="lazy" decoding="async" />
      </a>
    )}

    {rest.length > 0 && (
      <div class="promo-st2-row">
        {rest.map(({ alt, src, width, height }) => (
          <a href={externalLink} class="promo-st2-mini" aria-label={alt}>
            <img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
          </a>
        ))}
      </div>
    )}
  </div>
</section>
