---
import { getPromoPreview } from "@/lib/images";
import { PROMOTION_SECTION } from "@/data/content/promotionSection";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const [hero, mini] = getPromoPreview(2);
---

<section class="promo-spt2" aria-labelledby="promo-heading">
  <div class="promo-spt2-inner">
    {hero && (
      <a href={externalLink} class="promo-spt2-hero" aria-label={hero.alt}>
        <img src={hero.src} alt={hero.alt} width={hero.width} height={hero.height} loading="lazy" decoding="async" />
      </a>
    )}

    <div class="promo-spt2-row">
      <div class="promo-spt2-copy">
        <h2 id="promo-heading">{PROMOTION_SECTION.heading}</h2>
        <p id="sub-promo-heading">{PROMOTION_SECTION.description}</p>
      </div>
      {mini && (
        <a href={externalLink} class="promo-spt2-mini" aria-label={mini.alt}>
          <img src={mini.src} alt={mini.alt} width={mini.width} height={mini.height} loading="lazy" decoding="async" />
        </a>
      )}
    </div>
  </div>
</section>
