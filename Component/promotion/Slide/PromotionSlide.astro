---
import { PROMOS } from "@/lib/images";
import { PROMOTION_SECTION } from "@/data/content/promotionSection";

interface Props { externalLink: string; }
const { externalLink } = Astro.props;

const promos = PROMOS;
---

<section class="promo-slide" aria-labelledby="promo-heading">
  <div class="promo-slide-box">
    <header class="promo-slide-head">
      <h2 id="promo-heading">{PROMOTION_SECTION.heading}</h2>
      <div class="gold-line"></div>
      <p id="sub-promo-heading">{PROMOTION_SECTION.description}</p>
    </header>

    <div class="promo-slide-carousel" aria-label="สไลด์โปรโมชั่น" role="region">
      <div class="promo-slide-track" id="promo-slide-track">
        {promos.map(({ alt, src, width, height }, i) => (
          <a href={externalLink} class="promo-slide-item" aria-label={alt} data-index={i}>
            <img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
          </a>
        ))}
      </div>
    </div>

    <div class="promo-slide-cta">
      <a href="/promotions/" class="btn btn-outline-gold btn-lg">ดูโปรโมชั่นทั้งหมด →</a>
    </div>
  </div>
</section>

<script is:inline>
(function () {
  var track = document.getElementById("promo-slide-track");
  if (!track) return;

  var slides = track.querySelectorAll(".promo-slide-item");
  var total = slides.length;
  if (total === 0) return;

  var current = 0;
  var timer;

  function goTo(index) {
    current = (index + total) % total;
    track.style.transform = "translateX(-" + (current * 100) + "%)";
  }

  function start() {
    if (total < 2) return;
    timer = setInterval(function () { goTo(current + 1); }, 3000);
  }

  function stop() {
    clearInterval(timer);
  }

  track.addEventListener("touchstart", stop, { passive: true });
  track.addEventListener("touchend", function () { goTo(current); start(); }, { passive: true });

  goTo(0);
  start();
})();
</script>
