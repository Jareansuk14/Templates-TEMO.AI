---
import { LINE } from "@/config/site";
import { CONTACT_PAGE } from "@/data/content/contactPage";
import { LINE_QR } from "@/lib/images";
---

<section class="page-header">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb">
      <a href="/">หน้าแรก</a>
      <span class="breadcrumb-sep" aria-hidden="true">/</span>
      <span aria-current="page">ติดต่อเรา</span>
    </nav>
    <h1 id="contact-seo">{CONTACT_PAGE.heading}</h1>
    <p id="sub-contact-seo">{CONTACT_PAGE.description}</p>
  </div>
</section>

<section class="section" aria-labelledby="contact-heading">
  <div class="container">
    <div class="line-card">
      <div class="line-icon" aria-hidden="true">💬</div>
      <h2 id="contact-heading">แอดไลน์ติดต่อเราได้เลย</h2>
      <p>ทีมงานเราพร้อมตอบคุณตลอด 24 ชั่วโมง</p>
      <div class="line-qr">
        <img src={LINE_QR.src} alt={`QR Code LINE ${LINE.id}`} width={LINE_QR.width} height={LINE_QR.height} loading="lazy" decoding="async" />
      </div>
      <div class="line-id">{LINE.id}</div>
    </div>
  </div>
</section>
