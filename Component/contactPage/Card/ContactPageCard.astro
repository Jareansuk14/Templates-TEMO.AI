---
import { LINE } from "@/config/site";
import { CONTACT_PAGE } from "@/data/content/contactPage";
import { LINE_QR } from "@/lib/images";
const lineUrl = `https://line.me/ti/p/~${LINE.id}`;
---

<section class="cp-card-head">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">หน้าแรก</a><span class="breadcrumb-sep" aria-hidden="true">/</span><span aria-current="page">ติดต่อเรา</span></nav>
    <h1 id="contact-seo">{CONTACT_PAGE.heading}</h1>
    <p id="sub-contact-seo">{CONTACT_PAGE.description}</p>
  </div>
</section>

<section class="cp-card-sec" aria-labelledby="contact-heading">
  <div class="container">
    <div class="cp-card">
      <div class="cp-card-qr"><img src={LINE_QR.src} alt={`QR Code LINE ${LINE.id}`} width={LINE_QR.width} height={LINE_QR.height} loading="lazy" decoding="async" /></div>
      <div class="cp-card-body">
        <h2 id="contact-heading">แอดไลน์ติดต่อเราได้เลย</h2>
        <p>ทีมงานพร้อมตอบคุณตลอด 24 ชั่วโมง</p>
        <a href={lineUrl} class="cp-card-btn">{LINE.id}</a>
      </div>
    </div>
  </div>
</section>

<style>
.cp-card-head { padding: 2rem var(--container-pad) 1rem; text-align: center; }
.cp-card-head h1 { color: var(--color-text); font-size: var(--fz-page-title); margin: 0.75rem 0 0.5rem; }
.cp-card-head p { color: var(--color-text-muted); font-size: var(--fz-body); line-height: var(--lh-body); max-width: 640px; margin-inline: auto; }
.cp-card-sec { padding: 1rem var(--container-pad) 3rem; }
.cp-card-sec > .container { max-width: 820px; margin-inline: auto; }
.cp-card { display: grid; grid-template-columns: 200px 1fr; gap: 2rem; align-items: center; background: var(--color-bg-2); border: 1px solid var(--color-border-subtle); border-radius: var(--radius-xl); padding: 2rem; }
.cp-card-qr img { width: 100%; height: auto; display: block; border-radius: var(--radius-md); background: #fff; padding: 8px; }
.cp-card-body h2 { color: var(--color-text); font-size: var(--fz-card-title); margin: 0 0 0.5rem; }
.cp-card-body p { color: var(--color-text-muted); margin: 0 0 1.25rem; }
.cp-card-btn { display: inline-block; background: var(--color-primary); color: var(--color-on-primary); font-weight: 700; padding: 0.7rem 1.6rem; border-radius: var(--radius-pill); }
@media (max-width: 600px) { .cp-card { grid-template-columns: 1fr; text-align: center; justify-items: center; } }
</style>
