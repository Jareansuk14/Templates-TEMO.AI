---
import { LINE } from "@/config/site";
import { CONTACT_PAGE } from "@/data/content/contactPage";
import { LINE_QR } from "@/lib/images";
const lineUrl = `https://line.me/ti/p/~${LINE.id}`;
---

<section class="cp-gr-head">
  <div class="container">
    <nav class="breadcrumb" aria-label="Breadcrumb"><a href="/">หน้าแรก</a><span class="breadcrumb-sep" aria-hidden="true">/</span><span aria-current="page">ติดต่อเรา</span></nav>
    <h1 id="contact-seo">{CONTACT_PAGE.heading}</h1>
    <p id="sub-contact-seo">{CONTACT_PAGE.description}</p>
  </div>
</section>

<section class="cp-gr-sec" aria-labelledby="contact-heading">
  <div class="container">
    <div class="cp-gr-card">
      <h2 id="contact-heading">แอดไลน์ติดต่อเราได้เลย</h2>
      <p>ทีมงานพร้อมตอบคุณตลอด 24 ชั่วโมง</p>
      <div class="cp-gr-qr"><img src={LINE_QR.src} alt={`QR Code LINE ${LINE.id}`} width={LINE_QR.width} height={LINE_QR.height} loading="lazy" decoding="async" /></div>
      <a href={lineUrl} class="cp-gr-id">{LINE.id}</a>
    </div>
  </div>
</section>

<style>
.cp-gr-head { padding: 2rem var(--container-pad) 1rem; text-align: center; }
.cp-gr-head h1 { color: var(--color-text); font-size: var(--fz-page-title); margin: 0.75rem 0 0.5rem; }
.cp-gr-head p { color: var(--color-text-muted); font-size: var(--fz-body); line-height: var(--lh-body); max-width: 640px; margin-inline: auto; }
.cp-gr-sec { padding: 1rem var(--container-pad) 3.5rem; }
.cp-gr-sec > .container { max-width: 560px; margin-inline: auto; }
.cp-gr-card { text-align: center; background: linear-gradient(135deg, var(--color-primary), var(--color-accent)); border-radius: var(--radius-xl); padding: 2.5rem 2rem; color: var(--color-on-primary); }
.cp-gr-card h2 { font-size: var(--fz-section-title); margin: 0 0 0.5rem; color: var(--color-on-primary); }
.cp-gr-card p { margin: 0 0 1.5rem; opacity: 0.9; }
.cp-gr-qr { display: inline-block; background: #fff; padding: 12px; border-radius: var(--radius-lg); }
.cp-gr-qr img { width: 190px; height: auto; display: block; }
.cp-gr-id { display: block; margin-top: 1.25rem; font-weight: 800; font-size: var(--fz-card-title); color: var(--color-on-primary); }
</style>
