---
import { PROVIDER } from "@/lib/images";
---

<section class="prov-rule" aria-labelledby="providers-heading">
  <div class="container">
    <div class="prov-rule-head"><h2 id="providers-heading">ค่ายเกมชั้นนำที่ให้บริการ</h2></div>
    <div class="prov-rule-img">
      <img src={PROVIDER.src} alt={PROVIDER.alt} width={PROVIDER.width} height={PROVIDER.height} loading="lazy" decoding="async" />
    </div>
  </div>
</section>
