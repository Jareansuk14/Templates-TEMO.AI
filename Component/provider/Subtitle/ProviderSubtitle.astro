---
import { PROVIDER } from "@/lib/images";
---

<section class="prov-sub" aria-labelledby="providers-heading">
  <div class="container">
    <header class="prov-sub-head">
      <h2 id="providers-heading">ค่ายเกมชั้นนำที่ให้บริการ</h2>
      <p>รวมค่ายเกมยอดนิยมไว้ครบในที่เดียว เล่นได้ลื่นไหลทุกค่าย</p>
    </header>
    <div class="prov-sub-img">
      <img src={PROVIDER.src} alt={PROVIDER.alt} width={PROVIDER.width} height={PROVIDER.height} loading="lazy" decoding="async" />
    </div>
  </div>
</section>
