---
import { SEO_ARTICLE_IMAGES } from "@/lib/images";

const images = [SEO_ARTICLE_IMAGES["seo-1"], SEO_ARTICLE_IMAGES["seo-2"]];
---

<section class="seo-images-section" aria-label="ภาพประกอบเว็บไซต์">
  <div class="container">
    <div class="seo-slider">
      {images.map((img, i) => (
        <div class={`seo-slide${i === 0 ? " active" : ""}`}>
          <img
            src={img.src}
            alt={img.alt}
            width={img.width}
            height={img.height}
            loading={i === 0 ? "eager" : "lazy"}
            decoding="async"
          />
        </div>
      ))}
    </div>
  </div>
</section>
