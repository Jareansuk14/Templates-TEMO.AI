---
import { GAME_CARDS } from "@/lib/images";

interface Props {
  externalLink: string;
}
const { externalLink } = Astro.props;
---

<section class="section section-plain" aria-label="เกมที่ให้บริการ">
  <div class="container">
    <div class="grid-6-to-3">
      {GAME_CARDS.map(({ alt, src, width, height }) => (
        <a
          href={externalLink}
          class="game-img-card"
          aria-label={alt}
        >
          <img src={src} alt={alt} width={width} height={height} loading="lazy" decoding="async" />
        </a>
      ))}
    </div>
  </div>
</section>
