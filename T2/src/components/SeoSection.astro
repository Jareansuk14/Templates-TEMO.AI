---
import { BRAND_NAME } from "@/config/site";

const whySections = [
  {
    id: "seo-1",
    heading: "สล็อตเว็บตรงแตกจริง ค่า RTP ชัด โบนัสแน่น เปลี่ยนเกมไว ฝากถอนออโต้ รองรับทุกวอลเล็ต",
    desc: "BABYSHARK99 รวมสล็อตค่ายดังพร้อมข้อมูลสำคัญอย่างค่า RTP ระดับความผันผวน เพย์ไลน์ และรีวิวฟีเจอร์ก่อนลงเงิน ทดลองเล่นฟรี จับจังหวะด้วยโหมดเทอร์โบหรือออโต้แบบกำหนดรอบ ปรับงบและกำไร/ขาดทุนสูงสุดได้เอง ฝากถอนออโต้รองรับธนาคารและวอลเล็ต สลับเกมได้ทันที มีตัวกรอง Megaways ซื้อฟรีสปิน คลาสสิก และแจ็กพอตสะสม พร้อมสถิติฮอต/คูลอัปเดตต่อเนื่อง เล่นผ่านเว็บตรงเดียวกับ คาสิโนออนไลน์ บาคาร่า แทงบอล อย่างมั่นใจ",
  },
  {
    id: "seo-2",
    heading: "บาคาร่าสดเว็บตรง ภาพคม ลื่นไม่มีดีเลย์ มือถือเล่นสบาย ระบบออโต้ 24 ชม. ปลอดภัยสูง",
    desc: "บาคาร่าสดของ BABYSHARK99 ภาพคมชัด ดีเลย์ต่ำ เลือกห้องสปีด มัลติเบต สควีซ หรือโต๊ะพิเศษได้ตามสไตล์ มีเค้าไพ่พร้อม Roadmap เต็มรูปแบบ บันทึกผลย้อนหลัง ปุ่ม Rebet/Double และตั้งเดิมพันล่วงหน้า เหมาะทั้งมือใหม่และสายโปร โหมดเดโม่ให้ซ้อมก่อนจริง ฝากถอนออโต้เชื่อมธนาคารและวอลเล็ต 24 ชม. เล่นมือเดียวแนวตั้งหรือนอนก็ลื่น และสลับไปยัง คาสิโนออนไลน์ สล็อต หรือ แทงบอล ได้จากบัญชีเดียว",
  },
  {
    id: "seo-3",
    heading: "แทงบอลครบทุกลีก ราคาน้ำดี เว็บตรง มีสถิติสด-สตรีม ครบมือถือสะดวก ทีมงานไทย 24 ชม.",
    desc: "บน BABYSHARK99 แทงบอลได้ครบทุกลีก ตั้งแต่ยุโรป เอเชีย จนทัวร์นาเมนต์พิเศษ ครบตลาดก่อนแข่ง-สด สูงต่ำ แฮนดิแคป คอมโบ และสเต็ป มีค่าน้ำ MY/HK/EU ปรับเรียลไทม์ รองรับแคชเอาต์บางคู่ หน้าแมตช์มีสถิติสดและสตรีมช่วยตัดสินใจ เว็บตรงเสถียร ฝากถอนออโต้ผ่านธนาคารและวอลเล็ต ใช้งานมือถือสะดวก บัญชีเดียวเชื่อม คาสิโนออนไลน์ สล็อต บาคาร่า โปรเงื่อนไขชัด ตรวจสอบบิลและยอดคืนได้ทันที",
  },
];
---

{whySections.map(({ id, heading, desc }) => (
  <section id={id} class="seo-text-section" aria-labelledby={`${id}-title`}>
    <div class="container">
      <h2 id={`${id}-title`} class="seo-text-heading">
        <span class="section-brand">{BRAND_NAME}</span>{heading}
      </h2>
      <p id={`sub-${id}`} class="seo-text-desc">{desc}</p>
    </div>
  </section>
))}
