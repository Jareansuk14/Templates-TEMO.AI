---
import { BRAND_NAME } from "@/config/site";

const whySections = [
  {
    id: "seo-1",
    heading: "สล็อตเว็บตรง แตกหนัก RTP โปร่งใส โบนัสจัดเต็ม ฝากถอนออโต้ รองรับวอลเล็ต",
    desc: "MOOYIM99 คัดสรรสล็อตจากค่ายชั้นนำ พร้อมแสดงค่า RTP ความเสี่ยง เพย์ไลน์ และฟีเจอร์เด่นให้ตรวจสอบก่อนเล่น ทดลองหมุนฟรีเพื่อจับจังหวะ แล้วค่อยวางงบอย่างเป็นระบบ ฝากถอนออโต้รองรับทุกธนาคารและวอลเล็ต สลับเกมได้ทันที มีตัวกรองแนวฮิตอย่าง เมกะเวย์ ซื้อฟรีสปิน คลาสสิก และแจ็กพอตสะสม รีวิวโบนัสและสถิติอัปเดตต่อเนื่อง เล่นผ่านเว็บตรงเดียวกับ คาสิโนออนไลน์ บาคาร่า แทงบอล ได้อย่างมั่นใจ",
  },
  {
    id: "seo-2",
    heading: "บาคาร่าสดภาพชัด เว็บตรงลื่นไหล ระบบออโต้ 24 ชม. มือถือก็เล่นได้ ปลอดภัย",
    desc: "MOOYIM99 ให้บริการบาคาร่าสดผ่านเว็บตรงภาพคม เสียงชัด ดีเลย์ต่ำ มีห้องให้เลือกหลายสไตล์ทั้งสปีด มัลติเบต และสควีซ พร้อมสถิติ เค้าไพ่ และบันทึกผลย้อนหลังช่วยวิเคราะห์ได้จริง โหมดสาธิตเหมาะสำหรับมือใหม่ ก่อนย้ายไปเดิมพันเงินจริงอย่างมั่นใจ ฝากถอนออโต้เชื่อมธนาคารและวอลเล็ตตลอด 24 ชม. เล่นบนมือถือแนวตั้งหรือนอนก็ลื่น สลับไปยัง คาสิโนออนไลน์ สล็อต หรือ แทงบอล ได้ในบัญชีเดียว",
  },
  {
    id: "seo-3",
    heading: "แทงบอลครบลีก ราคาน้ำคุ้ม เว็บตรง สถิติสด ถ่ายทอดสด มือถือสะดวก บริการไทย 24 ชม.",
    desc: "ที่ MOOYIM99 คุณแทงบอลได้ทุกลีกตั้งแต่ยุโรป เอเชีย ไปจนทัวร์นาเมนต์พิเศษ มีทั้งก่อนแข่ง บอลสด สูงต่ำ และสเต็ป พร้อมราคาน้ำอัปเดตแบบเรียลไทม์ หน้าสถิติสดและฟีดภาพช่วยตัดสินใจแม่นยำ ระบบเว็บตรงเสถียร ฝากถอนออโต้รองรับธนาคารและวอลเล็ต เล่นผ่านมือถือได้สะดวก บัญชีเดียวเชื่อมต่อ คาสิโนออนไลน์ สล็อต และบาคาร่า เงื่อนไขโปรโมชันชัดเจน ตรวจสอบประวัติและยอดคืนได้ทันที",
  },
];
---

{whySections.map(({ id, heading, desc }) => (
  <section id={id} class="seo-text-section" aria-labelledby={`${id}-title`}>
    <div class="container">
      <h2 id={`${id}-title`} class="seo-text-heading">
        <span class="section-brand">{BRAND_NAME}</span>{heading}
      </h2>
      <p id={`sub-${id}`} class="seo-text-desc">{desc}</p>
    </div>
  </section>
))}
