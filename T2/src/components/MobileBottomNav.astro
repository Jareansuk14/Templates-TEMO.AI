---
import { EXTERNAL_LINK, isActivePath } from "@/config/site";

const currentPath = Astro.url.pathname;

type NavItem = {
  label: string;
  href: string;
  external: boolean;
  icon: "login" | "register" | "play" | "promo" | "contact";
  highlight?: boolean;
};

const items: NavItem[] = [
  { label: "เข้าสู่ระบบ", href: EXTERNAL_LINK, external: true, icon: "login" },
  { label: "สมัคร",       href: EXTERNAL_LINK, external: true, icon: "register" },
  { label: "เข้าเล่น",   href: EXTERNAL_LINK, external: true, icon: "play", highlight: true },
  { label: "โปรโมชั่น",  href: "/promotions/", external: false, icon: "promo" },
  { label: "ติดต่อเรา",  href: "/contact/",    external: false, icon: "contact" },
];

const isActive = (href: string) => isActivePath(currentPath, href);
---

<nav class="mobile-bottom-nav" aria-label="เมนูด้านล่าง">
  <ul role="list" class="mobile-bottom-nav-list">
    {items.map(({ label, href, external, icon, highlight }) => (
      <li>
        <a
          href={href}
          class:list={["mobile-bottom-nav-item", { "is-highlight": highlight, "is-active": !external && isActive(href) }]}
          aria-label={label}
          aria-current={!external && isActive(href) ? "page" : undefined}
        >
          <span class="mobile-bottom-nav-icon" aria-hidden="true">
            {icon === "login" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                <polyline points="10 17 15 12 10 7" />
                <line x1="15" y1="12" x2="3" y2="12" />
              </svg>
            )}
            {icon === "register" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M16 21v-2a4 4 0 0 0-4-4H6a4 4 0 0 0-4 4v2" />
                <circle cx="9" cy="7" r="4" />
                <line x1="19" y1="8" x2="19" y2="14" />
                <line x1="22" y1="11" x2="16" y2="11" />
              </svg>
            )}
            {icon === "play" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polygon points="5 3 19 12 5 21 5 3" />
              </svg>
            )}
            {icon === "promo" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="20 12 20 22 4 22 4 12" />
                <rect x="2" y="7" width="20" height="5" />
                <line x1="12" y1="22" x2="12" y2="7" />
                <path d="M12 7H7.5a2.5 2.5 0 0 1 0-5C11 2 12 7 12 7z" />
                <path d="M12 7h4.5a2.5 2.5 0 0 0 0-5C13 2 12 7 12 7z" />
              </svg>
            )}
            {icon === "contact" && (
              <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z" />
              </svg>
            )}
          </span>
          <span class="mobile-bottom-nav-label">{label}</span>
        </a>
      </li>
    ))}
  </ul>
</nav>
