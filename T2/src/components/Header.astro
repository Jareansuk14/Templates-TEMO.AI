---
import { EXTERNAL_LINK, NAV_LINKS, isActivePath } from "@/config/site";

const currentPath = Astro.url.pathname;
---

<header class="site-header" role="banner">
  <div class="container">
    <div class="header-inner">

      <nav class="main-nav" aria-label="เมนูหลัก">
        <ul role="list">
          {NAV_LINKS.map(({ href, label }) => (
            <li>
              <a href={href} aria-current={isActivePath(currentPath, href) ? "page" : undefined}>
                {label}
              </a>
            </li>
          ))}
        </ul>
      </nav>

      <div class="header-actions">
        <a href={EXTERNAL_LINK} class="btn btn-outline-gold btn-sm">เข้าสู่ระบบ</a>
        <a href={EXTERNAL_LINK} class="btn btn-gold btn-sm">สมัครสมาชิก</a>
      </div>

      <button class="nav-toggle" type="button" aria-controls="mobile-menu" aria-expanded="false" aria-label="เปิดเมนู">
        <span></span>
        <span></span>
        <span></span>
      </button>

    </div>
  </div>

  <div id="mobile-menu" class="mobile-menu" hidden>
    <nav aria-label="เมนูมือถือ">
      <ul role="list">
        {NAV_LINKS.map(({ href, label }) => (
          <li>
            <a href={href} aria-current={isActivePath(currentPath, href) ? "page" : undefined}>
              {label}
            </a>
          </li>
        ))}
        <li style="display:flex;gap:.5rem;padding:.5rem 1rem">
          <a href={EXTERNAL_LINK} class="btn btn-outline-gold btn-sm" style="flex:1">เข้าสู่ระบบ</a>
          <a href={EXTERNAL_LINK} class="btn btn-gold btn-sm" style="flex:1">สมัครสมาชิก</a>
        </li>
      </ul>
    </nav>
  </div>
</header>

<script>
  const toggle = document.querySelector(".nav-toggle") as HTMLButtonElement;
  const menu = document.getElementById("mobile-menu") as HTMLElement;

  toggle?.addEventListener("click", () => {
    const expanded = toggle.getAttribute("aria-expanded") === "true";
    const nextExpanded = !expanded;
    toggle.setAttribute("aria-expanded", String(nextExpanded));
    toggle.setAttribute("aria-label", nextExpanded ? "ปิดเมนู" : "เปิดเมนู");
    menu.hidden = expanded;
  });

  document.addEventListener("keydown", (event) => {
    if (event.key !== "Escape" || menu.hidden) return;
    menu.hidden = true;
    toggle?.setAttribute("aria-expanded", "false");
    toggle?.setAttribute("aria-label", "เปิดเมนู");
    toggle?.focus();
  });
</script>
