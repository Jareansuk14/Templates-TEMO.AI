---
import { getReviewPreview, REVIEW_PREVIEW_SIZE } from "@/lib/images";

const reviews = getReviewPreview(3);
const { width: rw, height: rh } = REVIEW_PREVIEW_SIZE;
---

<section class="review-section" aria-label="รีวิวจากผู้ใช้">
  <div class="container">
    <div class="review-grid">
      {reviews.map(({ src, alt }) => (
        <div class="review-item">
          <img src={src} alt={alt} width={rw} height={rh} loading="lazy" decoding="async" />
        </div>
      ))}
    </div>
    <div class="review-slider">
      {reviews.map(({ src, alt }, i) => (
        <div class={`review-slide${i === 0 ? " active" : ""}`}>
          <img src={src} alt={alt} width={rw} height={rh} loading={i === 0 ? "eager" : "lazy"} decoding="async" />
        </div>
      ))}
    </div>
  </div>
</section>
